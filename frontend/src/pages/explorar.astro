---
import Layout from '../layouts/Layout.astro';
---

<Layout title="EXPLORAR">
  <div class="page-title">
    <h1><span class="highlight">🔍</span> EXPLORAR</h1>
    <p>Seleccioná un dataset y Datlas te muestra todo su perfil: estadísticas, distribuciones, correlaciones.</p>
  </div>

  <div id="app" style="max-width:800px; margin:0 auto;">
    <div style="text-align:center; padding:3rem 2rem;">
      <div class="spinner" style="margin:0 auto;"></div>
      <p style="color:var(--color-text-dim); margin-top:1rem; font-size:.68rem; letter-spacing:.04em;">
        CONECTANDO CON EL SERVIDOR<span class="dots">...</span>
      </p>
    </div>
  </div>
</Layout>

<script is:inline>
(function() {
  const API = window.location.hostname === 'localhost' ? 'http://localhost:8000' : 'https://datlas-api.onrender.com';
  const API_KEY = 'dtl4s_7kXp9mW2qR5vY8bN3jH6cL0fA1eD';
  const el = document.getElementById('app');
  const params = new URLSearchParams(window.location.search);
  const fileFromUrl = params.get('file');
  let datasets = [];
  let selectedFile = '';
  let report = null;
  let activeTab = 'resumen';

  function $(id) { return document.getElementById(id); }

  function show(html) { el.innerHTML = html; }

  function showError(msg) {
    show(`<div class="glass-card" style="border-color:rgba(255,68,102,0.2); text-align:center; padding:2rem 1.5rem;">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="1.5" style="margin:0 auto .6rem;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <p style="color:var(--red); font-weight:600; font-size:.75rem; margin-bottom:.3rem;">ERROR DE CONEXIÓN</p>
      <p class="text-secondary" style="font-size:.62rem; max-width:320px; margin:0 auto .8rem;">${msg}</p>
      <button class="action-btn secondary sm" onclick="location.reload()">REINTENTAR</button>
    </div>`);
  }

  function renderSelector() {
    return `
      <div class="glass-card" style="padding:.8rem 1rem; margin-bottom:1rem;">
        <div style="display:flex; gap:.4rem; flex-wrap:wrap; align-items:center;">
          <span style="font-weight:600; font-size:.6rem; color:var(--color-text-dim); letter-spacing:.08em; text-transform:uppercase;">Dataset:</span>
          <select id="ds-select" style="flex:1; min-width:140px; font-size:.65rem;">
            ${datasets.map(d => `<option value="${d.filename}" ${d.filename === selectedFile ? 'selected' : ''}>${d.filename} (${d.size_kb} KB)</option>`).join('')}
          </select>
          <button id="go-btn" class="action-btn primary sm">EXPLORAR</button>
          <a href="/datlas/subir" class="action-btn secondary sm">+ SUBIR</a>
        </div>
      </div>`;
  }

  function renderTabs() {
    const tabs = [
      { id: 'resumen', label: 'RESUMEN' },
      { id: 'preview', label: 'VISTA' },
      { id: 'nulos', label: 'NULOS' },
      { id: 'numerico', label: 'NUMÉRICO' },
      { id: 'categorias', label: 'CATEGORÍAS' },
      { id: 'corr', label: 'CORRELACIONES' },
    ];
    return `<div class="tabs">
      ${tabs.map(t => `<button class="tab-btn ${activeTab === t.id ? 'active' : ''}" data-tab="${t.id}">${t.label}</button>`).join('')}
    </div>
    <div id="tab-content"></div>`;
  }

  function renderReport() {
    if (!report) return;
    const r = report;
    let html = renderSelector();
    html += renderTabs();
    show(html);
    renderTabContent(r);

    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        activeTab = btn.dataset.tab;
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        renderTabContent(r);
      });
    });
    document.getElementById('go-btn')?.addEventListener('click', () => {
      selectedFile = document.getElementById('ds-select').value;
      activeTab = 'resumen';
        show(`<div style="text-align:center; padding:2.5rem 1.5rem;">
          <div class="spinner" style="margin:0 auto;"></div>
          <div style="margin-top:.8rem;">
            <p style="color:var(--color-true); font-size:.72rem; font-weight:500; letter-spacing:.04em;">ANALIZANDO</p>
            <p style="color:var(--color-text-dim); font-size:.6rem; margin-top:.15rem;">${selectedFile}</p>
          </div>
        </div>`);
        doExplore();
    });
    document.getElementById('ds-select')?.addEventListener('change', (e) => {
      selectedFile = e.target.value;
    });
    setTimeout(renderCharts, 300);
  }

  function renderTabContent(r) {
    const tc = document.getElementById('tab-content');
    if (!tc) return;
    switch (activeTab) {
      case 'resumen': tc.innerHTML = renderResumen(r); break;
      case 'preview': tc.innerHTML = renderPreview(r); break;
      case 'nulos': tc.innerHTML = renderNulos(r); break;
      case 'numerico': tc.innerHTML = renderNumerico(r); break;
      case 'categorias': tc.innerHTML = renderCategorias(r); break;
      case 'corr': tc.innerHTML = renderCorrelaciones(r); break;
    }
  }

  function renderResumen(r) {
    const p = r.profile;
    const ns = r.null_summary;
    const nullColor = ns.total_nulls > 0 ? 'var(--yellow)' : 'var(--green)';
    const corr = r.correlations || {};
    const dist = r.distributions || {};

    let html = `
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(110px,1fr)); gap:.5rem; margin-bottom:1rem;">
        <div class="glass-card text-center" style="padding:.8rem;">
          <p style="font-size:1.5rem; font-weight:800; color:var(--color-true);">${p.shape.rows.toLocaleString()}</p>
          <p style="font-size:.48rem; color:var(--color-text-dim); letter-spacing:.12em;">FILAS</p>
        </div>
        <div class="glass-card text-center" style="padding:.8rem;">
          <p style="font-size:1.5rem; font-weight:800; color:var(--color-true);">${p.shape.columns}</p>
          <p style="font-size:.48rem; color:var(--color-text-dim); letter-spacing:.12em;">COLUMNAS</p>
        </div>
        <div class="glass-card text-center" style="padding:.8rem;">
          <p style="font-size:1.5rem; font-weight:800; color:${nullColor};">${ns.total_nulls}</p>
          <p style="font-size:.48rem; color:var(--color-text-dim); letter-spacing:.12em;">VACÍOS</p>
        </div>
        <div class="glass-card text-center" style="padding:.8rem;">
          <p style="font-size:1.5rem; font-weight:800; color:${nullColor};">${100 - ns.overall_pct}%</p>
          <p style="font-size:.48rem; color:var(--color-text-dim); letter-spacing:.12em;">COMPLETO</p>
        </div>
        <div class="glass-card text-center" style="padding:.8rem;">
          <p style="font-size:1.5rem; font-weight:800; color:var(--color-true);">${Object.keys(p.columns).length}</p>
          <p style="font-size:.48rem; color:var(--color-text-dim); letter-spacing:.12em;">NUMÉRICAS</p>
        </div>
        <div class="glass-card text-center" style="padding:.8rem;">
          <p style="font-size:1.5rem; font-weight:800; color:var(--color-true);">${Object.keys(dist).length}</p>
          <p style="font-size:.48rem; color:var(--color-text-dim); letter-spacing:.12em;">DISTRIBUCIONES</p>
        </div>
      </div>`;

    const numCols = Object.entries(p.columns).filter(([_, info]) => info.type !== 'object').length;
    const catCols = Object.entries(p.columns).filter(([_, info]) => info.type === 'object').length;

    html += `
      <div class="glass-card mb-2">
        <h3>COMPOSICIÓN</h3>
        <div style="display:flex; gap:1rem; flex-wrap:wrap;">
          <span class="badge badge-cyan">${numCols} numéricas</span>
          <span class="badge badge-yellow">${catCols} categóricas</span>
          <span class="badge ${ns.total_nulls > 0 ? 'badge-yellow' : 'badge-green'}">${ns.total_nulls > 0 ? ns.total_nulls + ' nulos' : 'Sin nulos'}</span>
          <span class="badge badge-cyan">${corr.pairs ? corr.pairs.length + ' correlaciones' : 'Sin correlaciones'}</span>
        </div>
      </div>`;

    const stats = r.statistics || {};
    const statCols = Object.keys(stats);
    if (statCols.length > 0) {
      html += `<div class="glass-card mb-2"><h3>FORMA DE DISTRIBUCIÓN</h3>
        <div style="overflow-x:auto; margin-top:.4rem;"><table>
          <tr><th>Columna</th><th style="text-align:right;">Sesgo</th><th></th><th style="text-align:right;">Curtosis</th><th></th></tr>`;
      for (const col of statCols) {
        const s = stats[col];
        const skewLabel = Math.abs(s.skewness) < 0.5 ? 'Simétrica' : s.skewness > 0 ? 'Sesgo +' : 'Sesgo −';
        const kurtLabel = Math.abs(s.kurtosis) < 1 ? 'Normal' : s.kurtosis > 0 ? 'Picuda' : 'Plana';
        html += `<tr>
          <td style="font-weight:500;">${col}</td>
          <td style="text-align:right;">${s.skewness}</td>
          <td style="font-size:.62rem; color:var(--color-text-dim);">${skewLabel}</td>
          <td style="text-align:right;">${s.kurtosis}</td>
          <td style="font-size:.62rem; color:var(--color-text-dim);">${kurtLabel}</td>
        </tr>`;
      }
      html += `</table></div></div>`;
    }
    return html;
  }

  function renderPreview(r) {
    if (!r.preview || r.preview.length === 0) {
      return `<div class="glass-card text-center"><p class="text-secondary" style="font-size:.68rem;">Sin datos de previsualización.</p></div>`;
    }
    const cols = Object.keys(r.preview[0]);
    let html = `<div class="glass-card"><h3>VISTA PREVIA</h3>
      <p class="text-secondary" style="font-size:.6rem; margin-bottom:.6rem;">Primeras ${r.preview.length} filas</p>
      <div style="overflow-x:auto;"><table>
        <tr>${cols.map(c => `<th style="white-space:nowrap; font-size:.55rem;">${c}</th>`).join('')}</tr>`;
    for (const row of r.preview) {
      html += `<tr>${cols.map(c => {
        const val = row[c] ?? '';
        return `<td style="max-width:100px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; font-size:.65rem;">${val}</td>`;
      }).join('')}</tr>`;
    }
    html += `</table></div></div>`;
    return html;
  }

  function renderNulos(r) {
    const ns = r.null_summary;
    const nullCols = Object.entries(ns.columns);
    if (nullCols.length === 0) {
      return `<div class="glass-card text-center" style="padding:1.5rem;">
        <p style="font-size:2rem; margin-bottom:.3rem;">✨</p>
        <p class="text-green" style="font-weight:600; font-size:.78rem;">Sin valores faltantes</p>
        <p class="text-secondary" style="font-size:.65rem;">Todas las columnas están completas.</p>
      </div>`;
    }
    let html = `<div class="glass-card"><h3>VALORES FALTANTES</h3>
      <p class="text-secondary" style="font-size:.62rem; margin-bottom:.8rem;">${ns.total_nulls} valores nulos (${ns.overall_pct}% del dataset)</p>`;
    for (const [col, info] of nullCols) {
      const p = Math.min(info.pct, 100);
      const barColor = p > 20 ? 'var(--red)' : p > 5 ? 'var(--yellow)' : 'var(--green)';
      html += `<div style="margin-bottom:.4rem;">
        <div style="display:flex; justify-content:space-between; font-size:.68rem; margin-bottom:.15rem;">
          <span style="font-weight:500;">${col}</span>
          <span class="${p > 20 ? 'text-red' : 'text-secondary'}" style="font-size:.62rem;">${info.count} filas (${info.pct}%)</span>
        </div>
        <div class="progress-bar"><div class="progress-fill" style="width:${p}%; background:${barColor};"></div></div>
      </div>`;
    }
    html += `</div>`;
    return html;
  }

  function renderNumerico(r) {
    const p = r.profile;
    const numCols = Object.entries(p.columns).filter(([_, info]) => info.type !== 'object');
    if (numCols.length === 0) {
      return `<div class="glass-card text-center"><p class="text-secondary" style="font-size:.68rem;">No hay columnas numéricas.</p></div>`;
    }
    let html = `<div class="glass-card"><h3>PERFIL NUMÉRICO</h3>
      <p class="text-secondary" style="font-size:.62rem; margin-bottom:.6rem;">Media, mediana, desvío, mínimo y máximo</p>
      <div style="overflow-x:auto;"><table>
        <tr><th>Columna</th><th>Tipo</th><th style="text-align:right;">∅</th><th style="text-align:right;">Únicos</th><th style="text-align:right;">Media</th><th style="text-align:right;">Mediana</th><th style="text-align:right;">Std</th><th style="text-align:right;">Mín</th><th style="text-align:right;">Máx</th></tr>`;
    for (const [col, info] of numCols) {
      html += `<tr>
        <td style="font-weight:600;">${col}</td>
        <td style="color:var(--color-true); font-size:.62rem;">${info.type}</td>
        <td style="text-align:right;">${info.nulls || 0}</td>
        <td style="text-align:right;">${info.unique ?? '—'}</td>
        <td style="text-align:right;">${info.mean !== undefined ? info.mean : '—'}</td>
        <td style="text-align:right;">${info.median !== undefined ? info.median : '—'}</td>
        <td style="text-align:right;">${info.std !== undefined ? info.std : '—'}</td>
        <td style="text-align:right;">${info.min !== undefined ? info.min : '—'}</td>
        <td style="text-align:right;">${info.max !== undefined ? info.max : '—'}</td>
      </tr>`;
    }
    html += `</table></div></div>`;

    const dist = r.distributions || {};
    const distCols = Object.keys(dist);
    if (distCols.length > 0) {
      html += `<div class="glass-card mt-1">
        <h3>DISTRIBUCIONES</h3>
        <p class="text-secondary" style="font-size:.62rem; margin-bottom:.6rem;">Histogramas de columnas numéricas</p>
        <div id="chart-area" style="display:grid; grid-template-columns:repeat(auto-fit, minmax(260px,1fr)); gap:.8rem;"></div>
      </div>`;
    }
    return html;
  }

  function renderCategorias(r) {
    const cat = r.categorical_breakdown || {};
    const catCols = Object.keys(cat);
    if (catCols.length === 0) {
      return `<div class="glass-card text-center"><p class="text-secondary" style="font-size:.68rem;">No hay columnas categóricas.</p></div>`;
    }
    let html = `<div class="glass-card"><h3>COLUMNAS DE TEXTO</h3>
      <p class="text-secondary" style="font-size:.62rem; margin-bottom:.8rem;">Distribución de valores por categoría</p>
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(250px,1fr)); gap:.8rem;">`;
    for (const col of catCols) {
      const items = cat[col];
      const maxCount = items[0]?.count || 1;
      html += `<div>
        <h4 style="color:var(--color-text-dim); font-size:.62rem; margin-bottom:.3rem; font-weight:600;">${col}</h4>`;
      for (const item of items) {
        html += `<div style="display:flex; align-items:center; gap:.3rem; margin-bottom:.15rem;">
          <span style="font-size:.6rem; width:80px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${item.value}</span>
          <div class="progress-bar" style="flex:1;"><div class="progress-fill" style="width:${(item.count / maxCount) * 100}%; background:var(--color-true);"></div></div>
          <span style="font-size:.55rem; color:var(--color-text-dim); width:36px; text-align:right;">${item.pct}%</span>
        </div>`;
      }
      html += `</div>`;
    }
    html += `</div></div>`;
    return html;
  }

  function renderCorrelaciones(r) {
    const corr = r.correlations || {};
    if (!corr.pairs || corr.pairs.length === 0) {
      return `<div class="glass-card text-center" style="padding:1.5rem;">
        <p style="font-size:2rem; margin-bottom:.3rem;">🔗</p>
        <p class="text-secondary" style="font-size:.68rem;">No hay suficientes columnas numéricas para correlaciones.</p>
      </div>`;
    }
    const corrCols = Object.keys(corr.matrix);
    let html = `<div class="glass-card mb-1"><h3>MATRIZ DE CORRELACIONES</h3>
      <p class="text-secondary" style="font-size:.62rem; margin-bottom:.6rem;">Rojo = negativa, Verde = positiva</p>`;

    if (corrCols.length > 1) {
      html += `<div style="overflow-x:auto; margin-bottom:.8rem;">
        <table style="font-size:.58rem; margin:0 auto;">
          <tr><td style="padding:.05rem;"></td>`;
      for (const c of corrCols) {
        html += `<th style="padding:.05rem; writing-mode:vertical-lr; font-weight:600; color:var(--color-text-dim); height:32px;">${c}</th>`;
      }
      html += `</tr>`;
      for (const c1 of corrCols) {
        html += `<tr><td style="padding:.05rem; font-weight:600; color:var(--color-text-dim); font-size:.55rem;">${c1}</td>`;
        for (const c2 of corrCols) {
          const val = corr.matrix[c1][c2];
          const bg = val >= 0
            ? `rgba(34,197,94,${Math.abs(val) * 0.5 + 0.08})`
            : `rgba(239,68,68,${Math.abs(val) * 0.5 + 0.08})`;
          html += `<td style="padding:.05rem; text-align:center; background:${bg}; border-radius:2px; min-width:28px; font-weight:${Math.abs(val) > 0.7 ? '700' : '400'};">${val.toFixed(2)}</td>`;
        }
        html += `</tr>`;
      }
      html += `</table></div>`;
    }

    html += `<h4 style="color:var(--color-text-dim); font-size:.68rem; margin-bottom:.4rem;">Pares más correlacionados</h4>
      <table>
        <tr><th>X</th><th>Y</th><th style="text-align:right;">Valor</th><th>Relación</th></tr>`;
    for (const p of corr.pairs.slice(0, 5)) {
      const color = p.correlation >= 0 ? 'var(--green)' : 'var(--red)';
      const label = p.correlation >= 0.7 ? 'Fuerte +' : p.correlation <= -0.7 ? 'Fuerte −' : p.correlation >= 0.4 ? 'Moderada +' : p.correlation <= -0.4 ? 'Moderada −' : 'Débil';
      html += `<tr>
        <td>${p.x}</td>
        <td>${p.y}</td>
        <td style="text-align:right; color:${color}; font-weight:600;">${p.correlation.toFixed(3)}</td>
        <td style="font-size:.65rem;">${label}</td>
      </tr>`;
    }
    html += `</table></div>`;

    const stats = r.statistics || {};
    const sCols = Object.keys(stats);
    if (sCols.length > 0) {
      html += `<div class="glass-card mt-1"><h3>FORMA DE DISTRIBUCIÓN</h3>
        <div style="overflow-x:auto; margin-top:.4rem;"><table>
          <tr><th>Columna</th><th style="text-align:right;">Sesgo</th><th></th><th style="text-align:right;">Curtosis</th><th></th></tr>`;
      for (const col of sCols) {
        const s = stats[col];
        const skewLabel = Math.abs(s.skewness) < 0.5 ? 'Simétrica' : s.skewness > 0 ? 'Sesgo +' : 'Sesgo −';
        const kurtLabel = Math.abs(s.kurtosis) < 1 ? 'Normal' : s.kurtosis > 0 ? 'Picuda' : 'Plana';
        html += `<tr>
          <td style="font-weight:500;">${col}</td>
          <td style="text-align:right;">${s.skewness}</td>
          <td style="font-size:.55rem; color:var(--color-text-dim);">${skewLabel}</td>
          <td style="text-align:right;">${s.kurtosis}</td>
          <td style="font-size:.55rem; color:var(--color-text-dim);">${kurtLabel}</td>
        </tr>`;
      }
      html += `</table></div></div>`;
    }
    return html;
  }

  fetch(`${API}/api/datasets`, { headers: { 'X-API-Key': API_KEY } })
    .then(r => r.json())
    .then(data => {
      datasets = data.raw || [];
      if (fileFromUrl && datasets.some(d => d.filename === fileFromUrl)) {
        selectedFile = fileFromUrl;
        show(`<div style="text-align:center; padding:2.5rem 1.5rem;">
          <div class="spinner" style="margin:0 auto;"></div>
          <div style="margin-top:.8rem;">
            <p style="color:var(--color-true); font-size:.72rem; font-weight:500; letter-spacing:.04em;">CARGANDO DATASET</p>
            <p style="color:var(--color-text-dim); font-size:.6rem; margin-top:.15rem;">${selectedFile}</p>
          </div>
        </div>`);
        doExplore();
      } else if (datasets.length > 0) {
        selectedFile = datasets[0].filename;
        let html = renderSelector();
        html += `<div class="glass-card" style="text-align:center; padding:2rem 1.5rem;">
          <div style="width:44px;height:44px;border-radius:12px;border:1px solid var(--border-glass);background:rgba(0,240,255,0.04);display:flex;align-items:center;justify-content:center;margin:0 auto .8rem;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-true)" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
          </div>
          <p style="font-size:.75rem; font-weight:600; letter-spacing:.04em; margin-bottom:.2rem;">SELECCIONÁ UN DATASET</p>
          <p class="text-secondary" style="font-size:.62rem;">Elegí un dataset de la lista y hace click en <strong style="color:var(--color-true); font-weight:600;">EXPLORAR</strong>.</p>
        </div>`;
        show(html);
        document.getElementById('go-btn')?.addEventListener('click', () => {
          selectedFile = document.getElementById('ds-select').value;
          show(`<div style="text-align:center; padding:2.5rem 1.5rem;">
          <div class="spinner" style="margin:0 auto;"></div>
          <div style="margin-top:.8rem;">
            <p style="color:var(--color-true); font-size:.72rem; font-weight:500; letter-spacing:.04em;">ANALIZANDO</p>
            <p style="color:var(--color-text-dim); font-size:.6rem; margin-top:.15rem;">${selectedFile}</p>
          </div>
        </div>`);
          doExplore();
        });
        document.getElementById('ds-select')?.addEventListener('change', (e) => {
          selectedFile = e.target.value;
        });
      } else {
        show(`<div class="glass-card" style="text-align:center; padding:2.5rem 1.5rem;">
          <div style="width:48px;height:48px;border-radius:14px;border:1px solid var(--border-glass);background:rgba(0,240,255,0.04);display:flex;align-items:center;justify-content:center;margin:0 auto .8rem;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-true)" stroke-width="1.5" opacity=".6"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <p style="font-size:.8rem; font-weight:600; letter-spacing:.04em; margin-bottom:.2rem;">NO HAY DATASETS</p>
          <p class="text-secondary" style="font-size:.62rem; max-width:280px; margin:0 auto 1rem;">Subí un CSV primero para poder explorarlo.</p>
          <a href="/datlas/subir" class="action-btn primary sm">SUBIR DATASET</a>
        </div>`);
      }
    })
    .catch(err => showError('No se pudo conectar con la API. ¿Docker está corriendo?'));

  function doExplore() {
    fetch(`${API}/api/explore/analyze`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-API-Key': API_KEY },
      body: JSON.stringify({ filename: selectedFile }),
    })
      .then(r => r.json())
      .then(data => {
        if (!data.report) {
          showError(data.detail || 'El servidor no devolvió un reporte válido.');
          return;
        }
        report = data.report;
        renderReport();
      })
      .catch(err => showError('Error de red. ¿La API está disponible?'));
  }

  function renderCharts() {
    const dist = report?.distributions;
    if (!dist) return;
    const container = document.getElementById('chart-area');
    if (!container) return;
    const cols = Object.keys(dist);
    if (cols.length === 0) return;

    if (!window.Chart) {
      const s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/chart.js';
      s.onload = () => drawAll(container, dist, cols);
      document.head.appendChild(s);
    } else {
      drawAll(container, dist, cols);
    }
  }

  function drawAll(container, dist, cols) {
    container.innerHTML = '';
    for (const col of cols) {
      const d = dist[col];
      const id = `ct-${col.replace(/[^a-zA-Z0-9]/g, '_')}`;
      const wrap = document.createElement('div');
      wrap.innerHTML = `<h4 style="font-size:.65rem; font-weight:600; margin-bottom:.2rem;">${col}</h4>
        <div style="position:relative; height:140px;"><canvas id="${id}"></canvas></div>`;
      const labels = d.edges.slice(0, -1).map((e, i) => `${d.edges[i].toFixed(1)}–${d.edges[i+1].toFixed(1)}`);
      container.appendChild(wrap);
      setTimeout(() => {
        const ctx = document.getElementById(id)?.getContext('2d');
        if (!ctx) return;
        new Chart(ctx, {
          type: 'bar',
          data: {
            labels,
            datasets: [{
              label: col, data: d.counts,
              backgroundColor: 'rgba(0, 240, 255, 0.2)',
              borderColor: 'rgba(0, 240, 255, 0.4)',
              borderWidth: 1, borderRadius: 3,
            }],
          },
          options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: { ticks: { color: '#5a5a72', font: { size: 8 }, maxRotation: 45 }, grid: { color: 'rgba(0,240,255,0.04)' } },
              y: { ticks: { color: '#5a5a72', font: { size: 8 } }, grid: { color: 'rgba(0,240,255,0.04)' }, beginAtZero: true },
            },
          },
        });
      }, 10);
    }
  }
})();
</script>

