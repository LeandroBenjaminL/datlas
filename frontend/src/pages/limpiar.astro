---
import Layout from '../layouts/Layout.astro';
---

<Layout title="LIMPIAR">
  <div class="page-title">
    <h1><span class="highlight">🧹</span> LIMPIAR</h1>
    <p>Analizá tu dataset y corregí problemas automáticamente.</p>
  </div>

  <div id="app" style="max-width:640px; margin:0 auto;"></div>
</Layout>

<script>
  const API = '';
  const app = document.getElementById('app');

  const params = new URLSearchParams(window.location.search);
  const fileParam = params.get('file');

  let state = 'loading';
  let datasets = [];
  let filename = fileParam || '';
  let report = null;
  let cleaningResult = null;

  async function init() {
    try {
      const res = await fetch(`${API}/api/datasets`);
      const data = await res.json();
      datasets = data.raw || [];
    } catch {}

    if (filename && datasets.some(d => d.filename === filename)) {
      state = 'analyzing';
      render();
      await runAnalyze();
    } else if (datasets.length > 0) {
      filename = datasets[0].filename;
      state = 'ready';
      render();
    } else {
      state = 'no-data';
      render();
    }
  }

  async function runAnalyze() {
    state = 'analyzing';
    render();
    try {
      const res = await fetch(`${API}/api/clean/analyze`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ filename }),
      });
      const data = await res.json();
      if (!res.ok) {
        state = 'error';
        report = data.detail;
        render();
        return;
      }
      report = data.report;
      state = 'report';
      render();
    } catch {
      state = 'error';
      report = 'Error de conexión con la API';
      render();
    }
  }

  async function applyFixes() {
    const fixes = { fill_nulls: {}, remove_outliers: [] };
    let removeDuplicates = false;

    document.querySelectorAll('.fix-null:checked').forEach(cb => {
      fixes.fill_nulls[cb.dataset.col] = cb.dataset.strategy;
    });
    document.querySelectorAll('.fix-outlier:checked').forEach(cb => {
      fixes.remove_outliers.push(cb.dataset.col);
    });
    if (document.getElementById('fix-duplicates')?.checked) {
      removeDuplicates = true;
    }
    if (removeDuplicates) fixes.remove_duplicates = true;

    state = 'applying';
    render();

    try {
      const res = await fetch(`${API}/api/clean/apply`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ filename, fixes }),
      });
      const data = await res.json();
      if (!res.ok) {
        state = 'error';
        report = data.detail;
        render();
        return;
      }
      cleaningResult = data.cleaning_result;
      state = 'done';
      render();
      document.getElementById('done-result')?.scrollIntoView({ behavior: 'smooth' });
    } catch {
      state = 'error';
      report = 'Error de conexión';
      render();
    }
  }

  function render() {
    if (state === 'loading') {
      app.innerHTML = `<div class="text-center" style="padding:2.5rem 1.5rem;">
        <div class="spinner" style="margin:0 auto;"></div>
        <p style="color:var(--color-text-dim); margin-top:.8rem; font-size:.65rem; letter-spacing:.04em;">CARGANDO DATASETS</p>
      </div>`;
      return;
    }

    if (state === 'no-data') {
      app.innerHTML = `
        <div class="glass-card" style="text-align:center; padding:2.5rem 1.5rem;">
          <div style="width:48px;height:48px;border-radius:14px;border:1px solid var(--border-glass);background:rgba(0,240,255,0.04);display:flex;align-items:center;justify-content:center;margin:0 auto .8rem;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-true)" stroke-width="1.5" opacity=".6"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <p style="font-size:.8rem; font-weight:600; letter-spacing:.04em; margin-bottom:.2rem;">NO HAY DATASETS</p>
          <p class="text-secondary" style="font-size:.62rem; margin-bottom:1rem;">Subí un CSV primero para poder limpiarlo.</p>
          <a href="/datlas/subir" class="action-btn primary sm">SUBIR DATASET</a>
        </div>
      `;
      return;
    }

    let html = `
      <div style="display:flex; gap:.4rem; margin-bottom:1rem; flex-wrap:wrap;">
        <select id="ds-select" style="flex:1; min-width:140px; font-size:.65rem;">
          ${datasets.map(d => `<option value="${d.filename}" ${d.filename === filename ? 'selected' : ''}>${d.filename}</option>`).join('')}
        </select>
        <button id="analyze-btn" class="action-btn primary sm">${state === 'analyzing' ? 'ANALIZANDO...' : 'ANALIZAR'}</button>
      </div>
    `;

    if (state === 'analyzing') {
      html += `<div class="text-center" style="padding:2.5rem 1.5rem;">
        <div class="spinner" style="margin:0 auto;"></div>
        <div style="margin-top:.8rem;">
          <p style="color:var(--color-true); font-size:.72rem; font-weight:500; letter-spacing:.04em;">ANALIZANDO</p>
          <p style="color:var(--color-text-dim); font-size:.6rem; margin-top:.15rem;">${filename}</p>
        </div>
      </div>`;
      app.innerHTML = html;
      bindEvents();
      return;
    }

    if (state === 'report' && report) {
      const r = report;
      const nullKeys = Object.keys(r.nulls);
      const outKeys = Object.keys(r.outliers);
      const hasDupes = r.duplicates.total_duplicate_rows > 0;
      const totalIssues = nullKeys.length + outKeys.length + (hasDupes ? 1 : 0);

      html += `
        <div class="glass-card mb-2">
          <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:.4rem;">
            <div>
              <h3 style="margin:0; font-size:.8rem;">${filename}</h3>
              <p class="text-secondary" style="font-size:.6rem;">${r.original_shape.rows} filas × ${r.original_shape.columns} columnas</p>
            </div>
            <span class="badge ${totalIssues > 0 ? 'badge-yellow' : 'badge-green'}">
              ${totalIssues > 0 ? `${totalIssues} problema${totalIssues > 1 ? 's' : ''}` : 'Sin problemas'}
            </span>
          </div>
        </div>
      `;

      html += `<div class="glass-card mb-2"><h3>VALORES NULOS</h3>`;
      if (nullKeys.length === 0) {
        html += `<p class="text-green mt-1" style="font-size:.72rem;">✅ No hay valores nulos en ninguna columna.</p>`;
      } else {
        html += `<div style="overflow-x:auto; margin-top:.4rem;"><table>
          <tr><th>Columna</th><th style="text-align:right;">Nulos</th><th style="text-align:right;">%</th><th>Sugerencia</th></tr>`;
        for (const col of nullKeys) {
          html += `<tr>
            <td style="font-weight:500;">${col}</td>
            <td style="text-align:right;">${r.nulls[col].null_count}</td>
            <td style="text-align:right;">${r.nulls[col].null_percent}%</td>
            <td><span class="badge badge-cyan">${r.nulls[col].suggested_fix}</span></td>
          </tr>`;
        }
        html += `</table></div>`;
      }
      html += `</div>`;

      html += `<div class="glass-card mb-2"><h3>OUTLIERS</h3>`;
      if (outKeys.length === 0) {
        html += `<p class="text-green mt-1" style="font-size:.72rem;">✅ No se detectaron valores atípicos.</p>`;
      } else {
        html += `<div style="overflow-x:auto; margin-top:.4rem;"><table>
          <tr><th>Columna</th><th style="text-align:right;">Outliers</th><th style="text-align:right;">%</th><th>Rango normal</th></tr>`;
        for (const col of outKeys) {
          html += `<tr>
            <td style="font-weight:500;">${col}</td>
            <td style="text-align:right; color:var(--red);">${r.outliers[col].outlier_count}</td>
            <td style="text-align:right;">${r.outliers[col].outlier_percent}%</td>
            <td style="font-size:.68rem; color:var(--color-text-dim);">[${r.outliers[col].lower_bound}, ${r.outliers[col].upper_bound}]</td>
          </tr>`;
        }
        html += `</table></div>`;
      }
      html += `</div>`;

      html += `<div class="glass-card mb-2"><h3>DUPLICADOS</h3>`;
      if (!hasDupes) {
        html += `<p class="text-green mt-1" style="font-size:.72rem;">✅ Sin filas duplicadas.</p>`;
      } else {
        html += `<p style="margin-top:.4rem;">${r.duplicates.total_duplicate_rows} filas duplicadas <span class="badge badge-yellow">${r.duplicates.duplicate_percent}% del total</span></p>`;
      }
      html += `</div>`;

      const hasIssues = nullKeys.length > 0 || outKeys.length > 0 || hasDupes;
      if (hasIssues) {
        html += `<div class="glass-card" style="border-color:rgba(0,240,255,0.12);">
          <div style="display:flex; align-items:center; gap:.4rem; margin-bottom:.6rem;">
            <h3 style="margin:0; color:var(--green);">CORREGIR AHORA</h3>
          </div>
          <p class="text-secondary" style="font-size:.62rem; margin-bottom:.8rem;">Seleccioná qué correcciones aplicar.</p>`;

        if (nullKeys.length > 0) {
          html += `<p class="text-secondary mb-1" style="font-size:.62rem; font-weight:600;">Nulos</p>`;
          for (const col of nullKeys) {
            const fix = r.nulls[col].suggested_fix.includes('median') ? 'median'
                      : r.nulls[col].suggested_fix.includes('mode') ? 'mode' : 'drop';
            html += `<label class="fix-option">
              <input type="checkbox" class="fix-null" data-col="${col}" data-strategy="${fix}" checked />
              <span>${col}</span>
              <span class="fix-strategy">→ ${fix}</span>
            </label>`;
          }
        }

        if (outKeys.length > 0) {
          html += `<p class="text-secondary mb-1 mt-1" style="font-size:.62rem; font-weight:600;">Outliers</p>`;
          for (const col of outKeys) {
            html += `<label class="fix-option">
              <input type="checkbox" class="fix-outlier" data-col="${col}" checked />
              <span>${col}</span>
            </label>`;
          }
        }

        if (hasDupes) {
          html += `<p class="text-secondary mb-1 mt-1" style="font-size:.62rem; font-weight:600;">Duplicados</p>
            <label class="fix-option">
              <input type="checkbox" id="fix-duplicates" checked />
              <span>Remover ${r.duplicates.total_duplicate_rows} filas duplicadas</span>
            </label>`;
        }

        html += `<button id="apply-btn" class="action-btn success sm" style="width:100%; justify-content:center; margin-top:.6rem;">APLICAR CORRECCIONES</button>`;
        html += `</div>`;
      } else {
        html += `<div class="glass-card text-center" style="border-color:rgba(0,240,255,0.12);">
          <p style="font-size:1.8rem; margin-bottom:.3rem;">✨</p>
          <p class="text-green" style="font-weight:600; font-size:.78rem;">Dataset impecable</p>
          <p class="text-secondary" style="font-size:.65rem;">No necesita correcciones.</p>
          <a href="/datlas/explorar?file=${filename}" class="action-btn secondary sm mt-1">EXPLORAR</a>
        </div>`;
      }

      app.innerHTML = html;
      bindEvents();
    }

    if (state === 'applying') {
      html += `<div class="text-center" style="padding:2.5rem 1.5rem;">
        <div class="spinner" style="margin:0 auto;"></div>
        <p style="color:var(--color-true); margin-top:.8rem; font-size:.72rem; font-weight:500; letter-spacing:.04em;">APLICANDO CORRECCIONES</p>
      </div>`;
      app.innerHTML = html;
    }

    if (state === 'done' && cleaningResult) {
      const cr = cleaningResult;
      html += `
        <div id="done-result" class="glass-card mt-1" style="border-color:rgba(0,240,255,0.15);">
          <div class="text-center" style="padding:.3rem 0;">
            <p style="font-size:2rem; margin-bottom:.3rem;">✅</p>
            <h3 style="color:var(--green); font-size:.9rem; margin-bottom:.8rem;">DATASET LIMPIADO</h3>
            <div class="stats-row">
              <div class="stat">
                <span class="stat-value" style="color:var(--color-text-dim);">${cr.original_shape[0]}</span>
                <span class="stat-label">Antes</span>
              </div>
              <div class="stat">
                <span class="stat-value" style="color:var(--green);">${cr.new_shape[0]}</span>
                <span class="stat-label">Después</span>
              </div>
              <div class="stat">
                <span class="stat-value" style="color:var(--red);">-${cr.rows_removed}</span>
                <span class="stat-label">Eliminadas</span>
              </div>
            </div>
            <div class="fixes-list">
              <p style="font-size:.58rem; color:var(--color-text-dim); margin-bottom:.3rem; font-weight:600;">Correcciones aplicadas:</p>
              ${cr.applied_fixes.map(f => `<span class="fix-tag">${f}</span>`).join('')}
            </div>
            <div class="btn-group" style="justify-content:center; margin-top:1rem;">
              <a href="/api/download/clean_${filename}" class="action-btn success sm" download>DESCARGAR CSV</a>
              <a href="/datlas/explorar?file=clean_${filename}" class="action-btn primary sm">EXPLORAR</a>
              <button class="action-btn secondary sm" onclick="window.location='/datlas/limpiar?file=${filename}'">VOLVER</button>
            </div>
          </div>
        </div>
      `;

      app.innerHTML = html;
      bindEvents();
    }

    if (state === 'error') {
      html += `<div class="glass-card mt-1" style="border-color:var(--red); text-align:center;">
        <p style="color:var(--red); font-weight:600; font-size:.72rem;">❌ Error</p>
        <p class="text-secondary" style="font-size:.65rem;">${report}</p>
      </div>`;
      app.innerHTML = html;
      bindEvents();
    }

    if (state === 'ready') {
      html += `<div class="glass-card" style="text-align:center; padding:1.2rem;">
        <div style="display:flex; align-items:center; gap:.5rem; justify-content:center;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-true)" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
          <p style="font-size:.65rem; color:var(--color-text-dim); letter-spacing:.02em;">
            <span style="color:var(--color-text); font-weight:500;">${filename}</span> — listo
          </p>
        </div>
      </div>`;
      app.innerHTML = html;
      bindEvents();
    }
  }

  function bindEvents() {
    document.getElementById('analyze-btn')?.addEventListener('click', runAnalyze);
    document.getElementById('ds-select')?.addEventListener('change', (e) => {
      filename = e.target.value;
      state = 'ready';
      render();
    });
    document.getElementById('apply-btn')?.addEventListener('click', applyFixes);
  }

  init();
</script>

<style>
  .stats-row {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: .8rem;
    flex-wrap: wrap;
  }
  .stat { text-align: center; }
  .stat-value { font-size: 1.1rem; font-weight: 700; color: var(--color-true); display: block; }
  .stat-label { font-size: .5rem; color: var(--color-text-dim); letter-spacing: .1em; text-transform: uppercase; }

  .fixes-list { margin: .4rem 0; }
  .fix-tag {
    display: inline-block;
    padding: .08rem .4rem;
    margin: .08rem;
    background: var(--green-bg);
    color: var(--green);
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 20px;
    font-size: .55rem;
  }

  .fix-option {
    display: flex;
    align-items: center;
    gap: .35rem;
    margin-bottom: .15rem;
    font-size: .7rem;
    cursor: pointer;
    padding: .15rem .35rem;
    border-radius: 4px;
    transition: background .2s var(--ease-expo);
  }
  .fix-option:hover { background: rgba(0, 240, 255, 0.04); }
  .fix-option input { accent-color: var(--color-true); }
  .fix-strategy { color: var(--color-text-dim); font-size: .62rem; }
</style>
