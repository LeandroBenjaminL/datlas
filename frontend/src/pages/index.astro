---
import Layout from '../layouts/Layout.astro';
---

<Layout title="INICIO">
  <div style="text-align:center; padding:2rem 0 1rem;">
    <p style="display:inline-block; font-size:.5rem; font-weight:600; letter-spacing:.2em; color:var(--color-true); border:1px solid rgba(0,255,102,0.15); border-radius:20px; padding:.2rem .7rem; margin-bottom:.8rem; background:rgba(0,255,102,0.04); text-transform:uppercase;">Portfolio Project</p>
    <h1 style="font-size:2rem; font-weight:900; margin-bottom:.3rem; letter-spacing:-.02em; line-height:1.1;">Cargá, limpiá, <span style="color:var(--color-true);">explorá</span>.</h1>
    <p style="color:var(--color-text-dim); font-size:.7rem; max-width:380px; margin:0 auto 1rem;">Subí un CSV. Datlas lo analiza al toque. Sin instalar nada.</p>
  </div>

  <div class="card-grid">
    <a href="/datlas/procesar" style="text-decoration:none;color:inherit;display:block;">
      <div class="home-card">
        <div class="home-card-icon">🎯</div>
        <div class="home-card-title">Procesar dataset</div>
        <div class="home-card-desc">Subí un archivo CSV, limpiá datos sucios y explorá patrones. Tres herramientas en una.</div>
        <div style="margin-top:.8rem;display:flex;gap:.3rem;flex-wrap:wrap;">
          <span class="badge badge-cyan">Subir</span>
          <span class="badge badge-cyan">Limpiar</span>
          <span class="badge badge-cyan">Explorar</span>
        </div>
      </div>
    </a>
    <a href="/datlas/pipeline" style="text-decoration:none;color:inherit;display:block;">
      <div class="home-card">
        <div class="home-card-icon">⚡</div>
        <div class="home-card-title">Pipeline automático</div>
        <div class="home-card-desc">Todo en uno: subí, limpiá y explorá en un solo paso. Resultados combinados al instante.</div>
        <div style="margin-top:.8rem;display:flex;gap:.3rem;flex-wrap:wrap;">
          <span class="badge badge-green">Automático</span>
        </div>
      </div>
    </a>
  </div>

  <div class="glass-card" style="margin-bottom:1rem;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.5rem;flex-wrap:wrap;gap:.4rem;">
      <div style="display:flex;align-items:center;gap:.5rem;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-true)" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        <h3 style="font-size:.6rem;letter-spacing:.1em;margin:0;text-transform:uppercase;">MIS DATASETS</h3>
      </div>
      <span id="ds-count" class="badge badge-cyan" style="min-width:50px;">conectando...</span>
    </div>
    <div id="ds-body" style="min-height:40px;">
      <p class="text-secondary" style="text-align:center;padding:.8rem;font-size:.6rem;">conectando con el servidor...</p>
    </div>
  </div>

  <div style="text-align:center;margin-top:.5rem;">
    <a href="/datlas/procesar" class="action-btn primary sm">SUBIR NUEVO DATASET</a>
  </div>
</Layout>

<style>
  .home-card {
    background: #181818;
    border: 1px solid #2a2a2a;
    border-radius: 10px;
    padding: 1.5rem;
    transition: border-color .2s ease;
  }
  .home-card:hover {
    border-color: #00ff66;
  }
  .home-card-icon {
    font-size: 1.5rem;
    margin-bottom: .8rem;
  }
  .home-card-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: .4rem;
    line-height: 1.2;
  }
  .home-card-desc {
    font-size: .75rem;
    color: #6b7280;
    line-height: 1.5;
  }
</style>

<script>
  const API = window.location.hostname === 'localhost' ? 'http://localhost:8000' : 'https://datlas-api.onrender.com';
  const API_KEY = 'dtl4s_7kXp9mW2qR5vY8bN3jH6cL0fA1eD';
  fetch(`${API}/api/datasets`, { headers: { 'X-API-Key': API_KEY } })
    .then(r => r.json())
    .then(data => {
      const raw = data.raw || [];
      const processed = data.processed || [];
      const body = document.getElementById('ds-body');
      const count = document.getElementById('ds-count');
      if (!body) return;

      if (raw.length === 0) {
        count.textContent = 'vacío';
        count.className = 'badge badge-yellow';
        body.innerHTML = `
          <div style="text-align:center;padding:.5rem 0;">
            <p style="font-size:1.5rem;margin-bottom:.3rem;opacity:.4;">📭</p>
            <p class="text-secondary" style="font-size:.6rem;">Todavía no subiste ningún dataset.</p>
          </div>`;
        return;
      }

      count.textContent = `${raw.length} dataset${raw.length > 1 ? 's' : ''}`;
      count.className = 'badge badge-green';

      body.innerHTML = raw.map(d => {
        const isClean = processed.some(p => p.filename === `clean_${d.filename}`);
        return `<div style="display:flex;justify-content:space-between;align-items:center;padding:.5rem .6rem;border-radius:8px;transition:background .2s var(--ease-expo);gap:.5rem;flex-wrap:wrap;background:rgba(0,0,0,0.15);margin-bottom:.25rem;"
          onmouseenter="this.style.background='rgba(0,255,102,0.04)'" onmouseleave="this.style.background='rgba(0,0,0,0.15)'">
          <div style="display:flex;align-items:center;gap:.4rem;flex-wrap:wrap;">
            <span style="font-weight:600;font-size:.68rem;color:var(--color-text);">${d.filename}</span>
            <span style="color:var(--color-text-dim);font-size:.55rem;letter-spacing:.04em;">${d.size_kb} KB</span>
            ${isClean ? '<span class="badge badge-green" style="font-size:.48rem;">limpiado</span>' : ''}
          </div>
          <div style="display:flex;gap:.3rem;">
            <a href="/datlas/procesar?tab=clean&file=${d.filename}" class="action-btn secondary sm">LIMPIAR</a>
            <a href="/datlas/procesar?tab=explore&file=${d.filename}" class="action-btn primary sm">EXPLORAR</a>
          </div>
        </div>`;
      }).join('');
    })
    .catch(() => {
      const count = document.getElementById('ds-count');
      const body = document.getElementById('ds-body');
      if (count) { count.textContent = 'error'; count.className = 'badge badge-red'; }
      if (body) body.innerHTML = '<p class="text-secondary" style="text-align:center;padding:.8rem;color:var(--red);font-size:.6rem;">⚠️ No se pudo conectar con la API.</p>';
    });
</script>
