---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inicio">
  <section class="hero">
    <h1>Datlas</h1>
    <p>
      Cargá tu dataset, limpiá los datos, explorá patrones y exportá resultados.
      Todo en un solo lugar. Sin instalar nada.
    </p>
    <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
      <a href="/datlas/subir" class="btn btn-primary">Empezar ahora</a>
      <a href="https://github.com/LeandroBenjaminL/datlas" class="btn btn-outline">GitHub</a>
    </div>
  </section>

  <section>
    <h2 style="text-align:center; color:#94a3b8; font-size:1rem; text-transform:uppercase; letter-spacing:2px; margin-bottom:2rem;">Tres perfiles, una herramienta</h2>

    <div class="grid-3">
      <!-- Perfil A: Limpieza -->
      <div class="card">
        <span class="badge">Perfil A</span>
        <h3>🧹 Limpieza</h3>
        <p>
          Detecta nulos, outliers, duplicados y tipos incorrectos automáticamente.
          Normalizá tus datos en segundos.
        </p>
        <p style="margin-top:1rem;">
          <a href="/datlas/limpiar" style="color:#a78bfa; text-decoration:none; font-weight:600;">Limpiar dataset →</a>
        </p>
      </div>

      <!-- Perfil B: Exploración -->
      <div class="card">
        <span class="badge">Perfil B</span>
        <h3>🔍 Exploración</h3>
        <p>
          Perfil automático: distribuciones, correlaciones, estadísticas.
          Entendé tus datos antes de usarlos.
        </p>
        <p style="margin-top:1rem;">
          <a href="/datlas/explorar" style="color:#a78bfa; text-decoration:none; font-weight:600;">Explorar dataset →</a>
        </p>
      </div>

      <!-- Perfil C: Pipeline -->
      <div class="card">
        <span class="badge">Perfil C</span>
        <h3>⚡ Pipeline</h3>
        <p>
          Del dataset crudo al resultado en un flujo automatizado.
          Exportá a CSV, Excel, Parquet o directo a PostgreSQL.
        </p>
        <p style="margin-top:1rem; color:#4a4a6a;">
          <em>Próximamente</em>
        </p>
      </div>
    </div>
  </section>

  <section style="margin-top:4rem; text-align:center;">
    <h2 style="color:#c4b5fd; margin-bottom:1rem;">Stack profesional</h2>
    <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; color:#6b6b8a; font-size:0.9rem;">
      <span style="background:#12122a; padding:0.4rem 1rem; border-radius:6px; border:1px solid #1e1e3a;">Python 3.12</span>
      <span style="background:#12122a; padding:0.4rem 1rem; border-radius:6px; border:1px solid #1e1e3a;">FastAPI</span>
      <span style="background:#12122a; padding:0.4rem 1rem; border-radius:6px; border:1px solid #1e1e3a;">Pandas</span>
      <span style="background:#12122a; padding:0.4rem 1rem; border-radius:6px; border:1px solid #1e1e3a;">PostgreSQL</span>
      <span style="background:#12122a; padding:0.4rem 1rem; border-radius:6px; border:1px solid #1e1e3a;">Docker</span>
      <span style="background:#12122a; padding:0.4rem 1rem; border-radius:6px; border:1px solid #1e1e3a;">AWS Lambda</span>
      <span style="background:#12122a; padding:0.4rem 1rem; border-radius:6px; border:1px solid #1e1e3a;">Astro</span>
    </div>
  </section>
</Layout>
