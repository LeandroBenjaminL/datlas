---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inicio">
  <section class="hero">
    <h1>Cargá, limpiá, <span class="gradient">explorá</span>.</h1>
    <p class="hero-sub">
      Subí un CSV. Datlas lo analiza al toque. Sin instalarte nada, sin vueltas.
    </p>
    <a href="/datlas/subir" class="btn btn-primary btn-lg">
      📁 Subir tu primer dataset
    </a>
  </section>

  <div class="steps-flow">
    <div class="flow-step">
      <div class="flow-icon">📁</div>
      <div class="flow-body">
        <h3>Subí tu CSV</h3>
        <p>Arrastrá el archivo o seleccionálo. Datlas lo recibe, lo analiza y te muestra qué tiene adentro.</p>
      </div>
    </div>
    <div class="flow-arrow">↓</div>
    <div class="flow-step">
      <div class="flow-icon">🧹</div>
      <div class="flow-body">
        <h3>Limpialo</h3>
        <p>Detecta automáticamente nulos, outliers y duplicados. Corregí todo con un click y descargá el resultado limpio.</p>
      </div>
    </div>
    <div class="flow-arrow">↓</div>
    <div class="flow-step">
      <div class="flow-icon">🔍</div>
      <div class="flow-body">
        <h3>Exploralo</h3>
        <p>Perfil completo, distribuciones, correlaciones, estadísticas. Todo automático, todo visual, todo listo.</p>
      </div>
    </div>
  </div>

  <div class="features">
    <div class="card feature-card">
      <span class="feature-icon">⚡</span>
      <h3>Automático</h3>
      <p>Subí y ya. Datlas analiza, detecta problemas y te muestra resultados sin que toques una línea de código.</p>
    </div>
    <div class="card feature-card">
      <span class="feature-icon">🎯</span>
      <h3>Interactivo</h3>
      <p>Elegí qué corregir, explorá visualmente, decidí con datos. No sos un pasajero — manejás vos.</p>
    </div>
    <div class="card feature-card">
      <span class="feature-icon">📦</span>
      <h3>Portátil</h3>
      <p>Corre donde sea. Docker, local, cloud. Tus datasets viajan con vos, siempre disponibles.</p>
    </div>
  </div>

  <div id="dataset-list" class="card dataset-section">
    <div class="ds-header">
      <h3>📦 Datasets disponibles</h3>
      <span id="ds-count" class="badge badge-blue">cargando...</span>
    </div>
    <div id="ds-body" class="ds-body">
      <p class="text-secondary" style="text-align:center; padding:1rem;">Cargando datasets...</p>
    </div>
  </div>
</Layout>

<script>
  const API = 'http://localhost:8000';
  fetch(`${API}/api/datasets`)
    .then(r => r.json())
    .then(data => {
      const raw = data.raw || [];
      const processed = data.processed || [];
      const list = document.getElementById('dataset-list');
      const body = document.getElementById('ds-body');
      const count = document.getElementById('ds-count');
      if (!list) return;

      if (raw.length === 0) {
        count.textContent = 'vacío';
        count.className = 'badge badge-yellow';
        body.innerHTML = `
          <div class="ds-empty">
            <p style="font-size:2.5rem; margin-bottom:0.3rem;">📭</p>
            <p class="text-secondary">Todavía no subiste ningún dataset.</p>
            <a href="/datlas/subir" class="btn btn-primary btn-sm mt-1">📁 Subir tu primer CSV</a>
          </div>`;
        return;
      }

      count.textContent = `${raw.length} dataset${raw.length > 1 ? 's' : ''}`;
      count.className = 'badge badge-green';

      body.innerHTML = raw.map(d => {
        const isClean = processed.some(p => p.filename === `clean_${d.filename}`);
        return `<div class="ds-row">
          <div class="ds-info">
            <span class="ds-name">${d.filename}</span>
            <span class="ds-meta">${d.size_kb} KB</span>
            ${isClean ? '<span class="badge badge-green" style="font-size:0.65rem;">limpiado</span>' : ''}
          </div>
          <div class="ds-actions">
            <a href="/datlas/limpiar?file=${d.filename}" class="btn btn-outline btn-sm">🧹 Limpiar</a>
            <a href="/datlas/explorar?file=${d.filename}" class="btn btn-primary btn-sm">🔍 Explorar</a>
          </div>
        </div>`;
      }).join('');
    })
    .catch(() => {
      const count = document.getElementById('ds-count');
      const body = document.getElementById('ds-body');
      if (count) { count.textContent = 'error'; count.className = 'badge badge-red'; }
      if (body) body.innerHTML = `<p class="text-secondary" style="text-align:center; padding:1rem; color:var(--red);">⚠️ No se pudo conectar con la API.</p>`;
    });
</script>

<style>
  .hero {
    text-align: center;
    padding: 3.5rem 1rem 2.5rem;
  }
  .hero h1 {
    font-size: 2.8rem;
    font-weight: 900;
    margin-bottom: 0.6rem;
    line-height: 1.15;
  }
  .gradient {
    background: linear-gradient(135deg, var(--accent), #ec4899, var(--accent));
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 4s ease-in-out infinite;
  }
  @keyframes shimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .hero-sub {
    color: var(--text-secondary);
    font-size: 1.05rem;
    max-width: 480px;
    margin: 0 auto 1.8rem;
  }

  .steps-flow {
    max-width: 480px;
    margin: 0 auto 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .flow-step {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.2rem 1.5rem;
    width: 100%;
    transition: border-color 0.2s;
  }
  .flow-step:hover { border-color: var(--border-hover); }
  .flow-icon {
    font-size: 2rem;
    flex-shrink: 0;
  }
  .flow-body h3 { font-size: 1rem; margin-bottom: 0.2rem; }
  .flow-body p { font-size: 0.82rem; color: var(--text-secondary); line-height: 1.5; }
  .flow-arrow {
    font-size: 1.2rem;
    color: var(--text-muted);
    padding: 0.3rem 0;
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .feature-card { text-align: center; padding: 1.5rem 1rem; }
  .feature-icon { font-size: 2rem; display: block; margin-bottom: 0.5rem; }
  .feature-card h3 { font-size: 0.95rem; }
  .feature-card p { font-size: 0.8rem; color: var(--text-secondary); line-height: 1.5; }

  .dataset-section { margin-bottom: 1rem; }
  .ds-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.8rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .ds-header h3 { margin: 0; }
  .ds-body { min-height: 60px; }
  .ds-empty { text-align: center; padding: 0.5rem 0; }
  .ds-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 0.8rem;
    border-radius: var(--radius-sm);
    transition: background 0.15s;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .ds-row:hover { background: var(--accent-bg); }
  .ds-row + .ds-row { border-top: 1px solid var(--border); }
  .ds-info { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
  .ds-name { font-weight: 600; font-size: 0.88rem; }
  .ds-meta { color: var(--text-muted); font-size: 0.75rem; }
  .ds-actions { display: flex; gap: 0.3rem; }

  @media (max-width: 600px) {
    .hero { padding: 2rem 0.5rem 1.5rem; }
    .hero h1 { font-size: 2rem; }
    .ds-row { flex-direction: column; align-items: stretch; }
    .ds-actions { justify-content: flex-end; }
  }
</style>
