---
import Layout from '../layouts/Layout.astro';

const API_BASE = '';
---

<Layout title="SUBIR">
  <div class="page-title">
    <h1><span class="highlight">📁</span> SUBIR DATASET</h1>
    <p>Arrastrá tu archivo CSV o hace click para seleccionarlo. Soportamos archivos de hasta 100 MB.</p>
  </div>

  <div style="max-width:480px; margin:0 auto;">
    <div id="dropzone" class="dropzone">
      <div class="dropzone-inner">
        <div class="dz-icon-wrap">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        </div>
        <p class="dz-title">ARRASTRÁ TU ARCHIVO ACÁ</p>
        <p class="dz-hint">o hace click para seleccionar</p>
        <span class="badge badge-cyan" style="margin-top:.2rem;">CSV · Máx 100 MB</span>
      </div>
      <input type="file" id="file-input" accept=".csv" />
    </div>

    <div id="loading" class="loading-state">
      <div class="spinner" style="margin:0 auto;"></div>
      <p style="color:var(--color-text-dim); margin-top:.8rem; font-size:.62rem; letter-spacing:.04em;">SUBIENDO <span id="loading-name" style="color:var(--color-true);"></span></p>
    </div>

    <div id="results" class="results-area"></div>
  </div>
</Layout>

<script>
  const API = '';
  const dropzone = document.getElementById('dropzone');
  const fileInput = document.getElementById('file-input');
  const loading = document.getElementById('loading');
  const results = document.getElementById('results');
  const loadingName = document.getElementById('loading-name');

  dropzone.addEventListener('click', () => fileInput.click());

  ['dragover', 'dragleave', 'drop'].forEach(ev => {
    dropzone.addEventListener(ev, (e) => {
      e.preventDefault();
      if (ev === 'dragover') {
        dropzone.classList.add('dz-active');
      } else {
        dropzone.classList.remove('dz-active');
      }
      if (ev === 'drop' && e.dataTransfer.files.length > 0) {
        uploadFile(e.dataTransfer.files[0]);
      }
    });
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files.length > 0) uploadFile(fileInput.files[0]);
  });

  async function uploadFile(file) {
    if (!file.name.endsWith('.csv')) {
      results.innerHTML = `<div class="glass-card" style="border-color:var(--red); text-align:center;">
        <p style="font-size:1.8rem; margin-bottom:.3rem;">❌</p>
        <p style="color:var(--red); font-weight:600; font-size:.72rem;">SOLO ARCHIVOS .CSV</p>
        <p class="text-secondary" style="font-size:.65rem; margin-top:.3rem;">Seleccioná un archivo con extensión .csv</p>
        <button class="action-btn secondary sm mt-1" onclick="location.reload()">VOLVER</button>
      </div>`;
      results.classList.add('fade-in');
      return;
    }
    dropzone.style.display = 'none';
    loadingName.textContent = file.name;
    loading.style.display = 'block';

    const formData = new FormData();
    formData.append('file', file);

    try {
      const res = await fetch(`${API}/api/upload`, { method: 'POST', body: formData });
      const data = await res.json();
      loading.style.display = 'none';

      if (!res.ok) {
        results.innerHTML = `<div class="glass-card" style="border-color:var(--red); text-align:center;">
          <p style="font-size:1.8rem; margin-bottom:.3rem;">❌</p>
          <p style="color:var(--red); font-weight:600; font-size:.72rem;">${data.detail || 'Error al subir el archivo'}</p>
          <button class="action-btn secondary sm mt-1" onclick="location.reload()">INTENTAR DE NUEVO</button>
        </div>`;
        results.classList.add('fade-in');
        return;
      }

      results.innerHTML = `
        <div class="glass-card success-card fade-in">
          <div class="success-header">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <div>
              <h3 style="font-size:.85rem; color:var(--green);">${data.filename}</h3>
              <p class="text-secondary" style="font-size:.62rem;">Recibido y listo para procesar</p>
            </div>
          </div>

          <div class="stats-row">
            <div class="stat">
              <span class="stat-value">${data.rows}</span>
              <span class="stat-label">Filas</span>
            </div>
            <div class="stat">
              <span class="stat-value">${data.columns}</span>
              <span class="stat-label">Columnas</span>
            </div>
            <div class="stat">
              <span class="stat-value">${data.size_kb} KB</span>
              <span class="stat-label">Tamaño</span>
            </div>
          </div>

          <div class="cols-preview">
            <p class="cols-title">Columnas detectadas</p>
            <div class="cols-list">
              ${data.col_names.map(c => `<span class="col-tag">${c}</span>`).join('')}
            </div>
          </div>

          <div class="success-actions">
            <a href="/datlas/limpiar?file=${data.filename}" class="action-btn primary sm">LIMPIAR</a>
            <a href="/datlas/explorar?file=${data.filename}" class="action-btn secondary sm">EXPLORAR</a>
            <button class="action-btn secondary sm" onclick="location.reload()">SUBIR OTRO</button>
          </div>
        </div>
      `;
    } catch {
      loading.style.display = 'none';
      results.innerHTML = `<div class="glass-card" style="border-color:var(--red); text-align:center;">
        <p style="font-size:1.8rem; margin-bottom:.3rem;">⚠️</p>
        <p style="color:var(--red); font-weight:600; font-size:.72rem;">ERROR DE CONEXIÓN</p>
        <p class="text-secondary" style="font-size:.62rem;">¿La API está disponible?</p>
        <button class="action-btn secondary sm mt-1" onclick="location.reload()">REINTENTAR</button>
      </div>`;
      results.classList.add('fade-in');
    }
  }
</script>

<style>
  .dropzone {
    border: 1.5px dashed rgba(0, 240, 255, 0.12);
    border-radius: var(--radius);
    background: var(--color-gate-bg);
    border-color: var(--color-gate-border);
    cursor: pointer;
    transition: all .3s var(--ease-expo);
    position: relative;
    overflow: hidden;
  }
  .dropzone::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(0, 240, 255, 0.04), transparent 70%);
    opacity: 0;
    transition: opacity .3s var(--ease-expo);
  }
  .dropzone:hover::before, .dropzone.dz-active::before { opacity: 1; }
  .dropzone:hover { border-color: rgba(0, 240, 255, 0.2); }
  .dropzone input { display: none; }
  .dropzone-inner {
    position: relative;
    padding: 2.5rem 1.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .2rem;
  }
  .dz-icon-wrap {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    border: 1px solid var(--color-gate-border);
    background: var(--bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: .4rem;
    color: var(--color-true);
    opacity: .6;
    transition: opacity .3s var(--ease-expo);
  }
  .dropzone:hover .dz-icon-wrap, .dz-active .dz-icon-wrap { opacity: 1; }
  .dz-title { color: var(--color-text); font-weight: 600; font-size: .75rem; letter-spacing: .06em; }
  .dz-hint { color: var(--color-text-dim); font-size: .6rem; }
  .dz-active {
    border-color: rgba(0, 240, 255, 0.3);
    background: rgba(0, 240, 255, 0.06);
  }

  .loading-state {
    display: none;
    text-align: center;
    padding: 2rem 1.5rem;
  }

  .results-area { margin-top: 1rem; }

  .success-card { border-color: rgba(0, 240, 255, 0.15); }
  .success-header {
    display: flex;
    align-items: center;
    gap: .6rem;
    margin-bottom: .8rem;
    padding-bottom: .6rem;
    border-bottom: 1px solid var(--color-gate-border);
  }
  .success-header h3 { margin: 0; }

  .stats-row {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: .8rem;
    flex-wrap: wrap;
  }
  .stat { text-align: center; }
  .stat-value { font-size: 1.2rem; font-weight: 700; color: var(--color-true); display: block; }
  .stat-label { font-size: .5rem; color: var(--color-text-dim); letter-spacing: .1em; text-transform: uppercase; }

  .cols-preview { margin-bottom: .8rem; }
  .cols-title { font-size: .58rem; color: var(--color-text-dim); margin-bottom: .35rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; }
  .cols-list { display: flex; flex-wrap: wrap; gap: .25rem; }
  .col-tag {
    padding: .08rem .4rem;
    background: rgba(0, 240, 255, 0.06);
    color: var(--color-true);
    border: 1px solid var(--color-gate-border);
    border-radius: 20px;
    font-size: .58rem;
    font-weight: 500;
  }

  .success-actions {
    display: flex;
    gap: .4rem;
    justify-content: center;
    flex-wrap: wrap;
    padding-top: .6rem;
    border-top: 1px solid var(--color-gate-border);
  }
</style>
