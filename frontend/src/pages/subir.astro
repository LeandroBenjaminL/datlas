---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Subir dataset">
  <div class="page-title">
    <h1>📁 Subir dataset</h1>
    <p>Arrastrá tu archivo CSV o hace click para seleccionarlo. Soportamos archivos de hasta 100 MB.</p>
  </div>

  <div style="max-width:520px; margin:0 auto;">
    <div id="dropzone" class="dropzone">
      <div class="dropzone-inner">
        <span class="dz-icon">📂</span>
        <p class="dz-title">Arrastrá tu archivo acá</p>
        <p class="dz-hint">o hace click para buscar</p>
        <span class="dz-badge badge badge-blue">CSV · Máx 100 MB</span>
      </div>
      <input type="file" id="file-input" accept=".csv" />
    </div>

    <div id="loading" class="loading-state">
      <div class="spinner"></div>
      <p>Subiendo <span id="loading-name"></span>...</p>
    </div>

    <div id="results" class="results-area"></div>
  </div>
</Layout>

<script>
  const API = 'http://localhost:8000';
  const dropzone = document.getElementById('dropzone');
  const fileInput = document.getElementById('file-input');
  const loading = document.getElementById('loading');
  const results = document.getElementById('results');
  const loadingName = document.getElementById('loading-name');

  dropzone.addEventListener('click', () => fileInput.click());

  ['dragover', 'dragleave', 'drop'].forEach(ev => {
    dropzone.addEventListener(ev, (e) => {
      e.preventDefault();
      if (ev === 'dragover') {
        dropzone.classList.add('dz-active');
      } else {
        dropzone.classList.remove('dz-active');
      }
      if (ev === 'drop' && e.dataTransfer.files.length > 0) {
        uploadFile(e.dataTransfer.files[0]);
      }
    });
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files.length > 0) uploadFile(fileInput.files[0]);
  });

  async function uploadFile(file) {
    if (!file.name.endsWith('.csv')) {
      results.innerHTML = `<div class="card" style="border-color:var(--red); text-align:center;">
        <p style="font-size:2rem; margin-bottom:0.3rem;">❌</p>
        <p style="color:var(--red); font-weight:600;">Solo archivos .csv</p>
        <p class="text-secondary" style="font-size:0.85rem; margin-top:0.3rem;">Seleccioná un archivo con extensión .csv</p>
        <button class="btn btn-outline btn-sm mt-1" onclick="location.reload()">Volver</button>
      </div>`;
      results.classList.add('fade-in');
      return;
    }
    dropzone.style.display = 'none';
    loadingName.textContent = file.name;
    loading.style.display = 'block';

    const formData = new FormData();
    formData.append('file', file);

    try {
      const res = await fetch(`${API}/api/upload`, { method: 'POST', body: formData });
      const data = await res.json();
      loading.style.display = 'none';

      if (!res.ok) {
        results.innerHTML = `<div class="card" style="border-color:var(--red); text-align:center;">
          <p style="font-size:2rem; margin-bottom:0.3rem;">❌</p>
          <p style="color:var(--red); font-weight:600;">${data.detail || 'Error al subir el archivo'}</p>
          <button class="btn btn-outline btn-sm mt-1" onclick="location.reload()">Intentar de nuevo</button>
        </div>`;
        results.classList.add('fade-in');
        return;
      }

      results.innerHTML = `
        <div class="card success-card fade-in">
          <div class="success-header">
            <span class="success-icon">✅</span>
            <div>
              <h3>${data.filename}</h3>
              <p class="text-secondary" style="font-size:0.82rem;">Recibido y listo para procesar</p>
            </div>
          </div>

          <div class="stats-row">
            <div class="stat">
              <span class="stat-value">${data.rows}</span>
              <span class="stat-label">Filas</span>
            </div>
            <div class="stat">
              <span class="stat-value">${data.columns}</span>
              <span class="stat-label">Columnas</span>
            </div>
            <div class="stat">
              <span class="stat-value">${data.size_kb} KB</span>
              <span class="stat-label">Tamaño</span>
            </div>
          </div>

          <div class="cols-preview">
            <p class="cols-title">Columnas detectadas</p>
            <div class="cols-list">
              ${data.col_names.map(c => `<span class="col-tag">${c}</span>`).join('')}
            </div>
          </div>

          <div class="success-actions">
            <a href="/datlas/limpiar?file=${data.filename}" class="btn btn-primary">
              🧹 Ir a limpiar
            </a>
            <a href="/datlas/explorar?file=${data.filename}" class="btn btn-outline">
              🔍 Explorar directo
            </a>
            <button class="btn btn-outline btn-sm" onclick="location.reload()">Subir otro</button>
          </div>
        </div>
      `;
    } catch {
      loading.style.display = 'none';
      results.innerHTML = `<div class="card" style="border-color:var(--red); text-align:center;">
        <p style="font-size:2rem; margin-bottom:0.3rem;">⚠️</p>
        <p style="color:var(--red); font-weight:600;">Error de conexión</p>
        <p class="text-secondary" style="font-size:0.85rem;">¿La API está corriendo en localhost:8000?</p>
        <button class="btn btn-outline btn-sm mt-1" onclick="location.reload()">Reintentar</button>
      </div>`;
      results.classList.add('fade-in');
    }
  }
</script>

<style>
  .dropzone {
    border: 2px dashed var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
    cursor: pointer;
    transition: all 0.25s;
    position: relative;
    overflow: hidden;
  }
  .dropzone::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(circle at 50% 50%, var(--accent-bg), transparent 70%);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .dropzone:hover::before, .dropzone.dz-active::before { opacity: 1; }
  .dropzone input { display: none; }
  .dropzone-inner {
    position: relative;
    padding: 3rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
  }
  .dz-icon { font-size: 3.5rem; margin-bottom: 0.3rem; }
  .dz-title { color: var(--text-primary); font-weight: 600; font-size: 1rem; }
  .dz-hint { color: var(--text-muted); font-size: 0.82rem; }
  .dz-badge { margin-top: 0.5rem; }
  .dz-active {
    border-color: var(--accent);
    background: var(--accent-bg);
  }

  .loading-state {
    display: none;
    text-align: center;
    padding: 3rem 2rem;
  }
  .loading-state p { color: var(--text-secondary); margin-top: 1rem; font-size: 0.9rem; }
  .spinner {
    width: 36px; height: 36px;
    border: 3px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .results-area { margin-top: 1.2rem; }

  .success-card { border-color: rgba(34, 197, 94, 0.3); }
  .success-header {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }
  .success-icon { font-size: 2rem; }
  .success-header h3 { margin: 0; font-size: 1.1rem; }

  .stats-row {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 1.2rem;
    flex-wrap: wrap;
  }
  .stat { text-align: center; }
  .stat-value { font-size: 1.4rem; font-weight: 700; color: var(--accent); display: block; }
  .stat-label { font-size: 0.7rem; color: var(--text-muted); letter-spacing: 0.5px; }

  .cols-preview { margin-bottom: 1.2rem; }
  .cols-title { font-size: 0.78rem; color: var(--text-secondary); margin-bottom: 0.5rem; font-weight: 600; }
  .cols-list { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .col-tag {
    padding: 0.15rem 0.5rem;
    background: var(--accent-bg);
    color: var(--accent-hover);
    border-radius: 20px;
    font-size: 0.72rem;
    font-weight: 500;
  }

  .success-actions {
    display: flex;
    gap: 0.6rem;
    justify-content: center;
    flex-wrap: wrap;
    padding-top: 0.8rem;
    border-top: 1px solid var(--border);
  }
</style>
