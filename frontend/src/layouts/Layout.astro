---
const { title = 'Datlas' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Datlas — Cargá, limpiá y explorá tus datasets en segundos." />
    <meta name="author" content="Leandro Benjamin Lopez" />
    <meta property="og:title" content="Datlas — Data Analysis Platform" />
    <meta property="og:description" content="Cargá, limpiá y explorá tus datasets en segundos." />
    <meta property="og:url" content="https://datlas-api.onrender.com" />
    <title>{title} · Datlas</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; }

      :root {
        --bg-primary: #0a0a0a;
        --bg-secondary: #111111;
        --bg-glass: rgba(17, 17, 17, 0.85);
        --border-glass: #1f1f1f;
        --color-true: #00ff66;
        --color-false: #1a1a2e;
        --color-true-glow: 0 0 20px rgba(0, 255, 102, 0.3), 0 0 60px rgba(0, 255, 102, 0.08);
        --color-accent: #7b61ff;
        --color-accent-glow: 0 0 15px rgba(123, 97, 255, 0.3);
        --color-danger: #ff4466;
        --color-danger-glow: 0 0 12px rgba(255, 68, 102, 0.3);
        --color-text: #ffffff;
        --color-text-dim: #6b7280;
        --color-gate-bg: #0d0d0d;
        --color-gate-border: #1f1f1f;
        --font-mono: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace;
        --font-sans: 'Inter', 'SF Pro', system-ui, sans-serif;
        --ease-expo: cubic-bezier(0.16, 1, 0.3, 1);
        --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
        --green: #22c55e;
        --green-bg: rgba(34, 197, 94, 0.1);
        --red: #ef4444;
        --red-bg: rgba(239, 68, 68, 0.1);
        --yellow: #f59e0b;
        --yellow-bg: rgba(245, 158, 11, 0.1);
        --radius: 8px;
        --radius-sm: 6px;
      }

      body {
        font-family: var(--font-sans);
        background: var(--bg-primary);
        color: var(--color-text);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      a { color: inherit; text-decoration: none; }

      .top-bar {
        position: sticky;
        top: 0;
        left: 0;
        right: 0;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 1.5rem;
        z-index: 200;
        border-bottom: 1px solid var(--border-glass);
        background: var(--bg-primary);
      }

      .app-title {
        font-family: var(--font-mono);
        font-size: .65rem;
        font-weight: 700;
        letter-spacing: .15em;
        color: var(--color-text);
        opacity: .5;
        transition: opacity .3s var(--ease-expo);
      }
      .app-title:hover { opacity: 1; color: var(--color-true); }

      .top-actions {
        display: flex;
        gap: .2rem;
        align-items: center;
      }

      .icon-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 6px;
        color: var(--color-text-dim);
        opacity: .4;
        transition: all .3s var(--ease-expo);
      }
      .icon-btn:hover {
        opacity: 1;
        color: var(--color-true);
        background: rgba(0, 255, 102, 0.06);
      }
      .icon-btn svg { width: 16px; height: 16px; }

      .action-btn {
        font-family: var(--font-sans);
        font-size: .55rem;
        font-weight: 600;
        letter-spacing: .06em;
        color: var(--color-text-dim);
        background: transparent;
        border: 1px solid var(--border-glass);
        border-radius: var(--radius-sm);
        padding: .45rem .9rem;
        cursor: pointer;
        transition: all .3s var(--ease-expo);
        white-space: nowrap;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        text-decoration: none;
        line-height: 1;
      }
      .action-btn:hover {
        color: var(--color-true);
        border-color: rgba(0, 240, 255, 0.2);
        box-shadow: var(--color-true-glow);
      }
      .action-btn:active { transform: scale(.97); }
      .action-btn.primary {
        color: var(--color-true);
        border-color: rgba(0, 255, 102, 0.25);
        background: rgba(0, 255, 102, 0.04);
      }
      .action-btn.primary:hover {
        border-color: var(--color-true);
        box-shadow: var(--color-true-glow);
        background: rgba(0, 255, 102, 0.08);
      }
      .action-btn.success {
        color: var(--green);
        border-color: rgba(0, 255, 102, 0.25);
        background: rgba(0, 255, 102, 0.04);
      }
      .action-btn.success:hover {
        border-color: var(--green);
        box-shadow: 0 0 15px rgba(0, 255, 102, 0.3);
        background: rgba(0, 255, 102, 0.08);
      }
      .action-btn.danger:hover {
        color: var(--color-danger);
        border-color: rgba(255, 68, 102, 0.2);
        box-shadow: var(--color-danger-glow);
      }
      .action-btn.secondary {
        border-color: var(--color-gate-border);
        color: var(--color-text-dim);
      }
      .action-btn.secondary:hover {
        border-color: var(--color-text-dim);
        color: var(--color-text);
      }
      .action-btn.sm { padding: .3rem .65rem; font-size: .52rem; }
      .action-btn.lg { padding: .55rem 1.2rem; font-size: .68rem; }

      main {
        flex: 1;
        max-width: 960px;
        margin: 0 auto;
        padding: 2rem 2rem;
        width: 100%;
      }

      footer {
        text-align: center;
        padding: .8rem 1.5rem;
        font-size: .5rem;
        color: var(--color-text-dim);
        border-top: 1px solid var(--border-glass);
      }
      footer .footer-name {
        color: var(--color-text);
        font-weight: 600;
      }
      footer .footer-links {
        display: flex;
        justify-content: center;
        gap: .8rem;
        margin-top: .2rem;
        font-size: .5rem;
        letter-spacing: .1em;
        text-transform: uppercase;
      }
      footer a {
        color: var(--color-text-dim);
        transition: color .3s var(--ease-expo);
      }
      footer a:hover { color: var(--color-true); }
      footer svg {
        width: 14px;
        height: 14px;
        vertical-align: middle;
      }

      .glass-card {
        background: #161616;
        border: 1px solid #262626;
        border-radius: 10px;
        padding: 1.5rem;
        transition: border-color .3s var(--ease-expo);
      }
      .glass-card:hover { border-color: rgba(0, 255, 102, 0.3); }
      .glass-card h3 {
        font-size: .65rem;
        font-weight: 600;
        letter-spacing: .1em;
        text-transform: uppercase;
        margin-bottom: .4rem;
        color: var(--color-text);
      }

      .badge {
        display: inline-flex; align-items: center; gap: .25rem;
        padding: .1rem .45rem;
        border-radius: 20px;
        font-size: .52rem;
        font-weight: 600;
        letter-spacing: .04em;
        border: 1px solid transparent;
      }
      .badge-green {
        border-color: rgba(34, 197, 94, 0.3);
        color: var(--green);
        background: var(--green-bg);
      }
      .badge-red {
        border-color: rgba(239, 68, 68, 0.3);
        color: var(--red);
        background: var(--red-bg);
      }
      .badge-yellow {
        border-color: rgba(245, 158, 11, 0.3);
        color: var(--yellow);
        background: var(--yellow-bg);
      }
      .badge-cyan {
        border-color: rgba(0, 255, 102, 0.2);
        color: var(--color-true);
        background: rgba(0, 255, 102, 0.06);
      }

      input, select, textarea {
        font-family: var(--font-mono);
        font-size: .72rem;
        padding: .4rem .65rem;
        border-radius: 8px;
        border: 1px solid var(--color-gate-border);
        background: var(--color-gate-bg);
        color: var(--color-text);
        outline: none;
        transition: border-color .25s var(--ease-expo);
      }
      input:focus, select:focus {
        border-color: var(--color-true);
        box-shadow: 0 0 10px rgba(0, 240, 255, 0.1);
      }
      select option { background: var(--bg-secondary); color: var(--color-text); }

      table { width: 100%; border-collapse: collapse; font-size: .72rem; }
      th {
        text-align: left;
        color: var(--color-text-dim);
        font-weight: 600;
        font-size: .6rem;
        letter-spacing: .08em;
        text-transform: uppercase;
      }
      td, th { padding: .25rem .45rem; }
      tr { border-bottom: 1px solid var(--border-glass); }

      .page-title {
        text-align: center;
        margin-bottom: 1.5rem;
      }
      .page-title h1 {
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        margin-bottom: .25rem;
      }
      .page-title h1 .highlight { color: var(--color-true); }
      .page-title p {
        color: var(--color-text-dim);
        font-size: .68rem;
        max-width: 440px;
        margin: 0 auto;
      }

      .btn-group { display: flex; gap: .4rem; flex-wrap: wrap; }
      .mt-1 { margin-top: .8rem; }
      .mt-2 { margin-top: 1.5rem; }
      .mb-1 { margin-bottom: .8rem; }
      .mb-2 { margin-bottom: 1.5rem; }
      .text-center { text-align: center; }
      .text-secondary { color: var(--color-text-dim); }
      .text-green { color: var(--green); }
      .text-red { color: var(--red); }
      .text-cyan { color: var(--color-true); }

      .fade-in { animation: fadeIn .4s var(--ease-expo); }
      @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

      .spinner {
        display: inline-block;
        width: 24px; height: 24px;
        border: 2px solid var(--color-gate-border);
        border-top-color: var(--color-true);
        border-radius: 50%;
        animation: spin .7s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }

      /* Tabs */
      .tab-bar {
        display: flex;
        gap: 0;
        margin-bottom: 1.2rem;
        border-bottom: 1px solid var(--border-glass);
      }
      .tab-btn {
        font-family: var(--font-mono);
        font-size: .6rem;
        font-weight: 600;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--color-text-dim);
        background: none;
        border: none;
        padding: .6rem 1rem;
        cursor: pointer;
        transition: all .3s var(--ease-expo);
        position: relative;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
      }
      .tab-btn {
        font-family: var(--font-sans);
        font-size: .58rem;
        font-weight: 600;
        letter-spacing: .06em;
        color: var(--color-text-dim);
        background: none;
        border: none;
        padding: .6rem 1rem;
        cursor: pointer;
        transition: all .3s var(--ease-expo);
        position: relative;
        border-bottom: 1.5px solid transparent;
        margin-bottom: -1px;
      }
      .tab-btn:hover { color: var(--color-text); }
      .tab-btn.active {
        color: var(--color-true);
        border-bottom-color: var(--color-true);
      }

      .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: .8rem;
        margin: 1.5rem 0;
      }
      .card-link {
        display: block;
        cursor: pointer;
      }
      .card-link .glass-card {
        cursor: pointer;
        transition: all .3s var(--ease-expo);
      }
      .card-link:hover .glass-card {
        border-color: rgba(0, 255, 102, 0.3);
        box-shadow: 0 0 25px rgba(0, 255, 102, 0.12);
        transform: translateY(-2px);
      }
      .card-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        border: 1px solid rgba(0, 255, 102, 0.12);
        background: rgba(0, 255, 102, 0.04);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem;
        margin-bottom: 1rem;
      }
      .card-title {
        font-size: 1.05rem;
        font-weight: 700;
        letter-spacing: -.02em;
        color: var(--color-text);
        margin-bottom: .5rem;
        line-height: 1.2;
      }
      .card-desc {
        font-size: .7rem;
        color: var(--color-text-dim);
        line-height: 1.6;
      }
      .card-badges {
        margin-top: 1rem;
        display: flex;
        gap: .3rem;
        flex-wrap: wrap;
      }

      @media (max-width: 600px) {
        html { font-size: 16px; }
        main { padding: 1rem; }
        .top-bar { padding: 0 1rem; }
        .card-grid { grid-template-columns: 1fr; }
        .icon-btn span { display: none; }
      }
    </style>
  </head>
  <body>
    <header class="top-bar">
      <a href="/datlas" class="app-title">DATLAS</a>
      <nav class="top-actions">
        <a href="https://github.com/LeandroBenjaminL/datlas" target="_blank" rel="noopener" class="icon-btn" title="GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="https://linkedin.com/in/leandrobackend" target="_blank" rel="noopener" class="icon-btn" title="LinkedIn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div>Built by <span class="footer-name">Leandro Benjamin Lopez</span></div>
      <div class="footer-links">
        <a href="https://github.com/LeandroBenjaminL" target="_blank" rel="noopener">GitHub</a>
        <a href="https://linkedin.com/in/leandrobackend" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://github.com/LeandroBenjaminL/datlas" target="_blank" rel="noopener">Datlas repo</a>
      </div>
    </footer>
  </body>
</html>
