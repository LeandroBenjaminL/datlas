---
const { title = 'Datlas' } = Astro.props;
const path = Astro.url.pathname;

const steps = [
  { label: 'Subir', icon: '📁', href: '/datlas/subir', desc: 'Cargá tu CSV' },
  { label: 'Limpiar', icon: '🧹', href: '/datlas/limpiar', desc: 'Corregí errores' },
  { label: 'Explorar', icon: '🔍', href: '/datlas/explorar', desc: 'Descubrí insights' },
];

function stepStatus(idx) {
  const p = path.replace(/\/$/, '');
  const href = steps[idx].href;
  if (p === href || p.startsWith(href + '/')) return 'active';
  for (let i = idx + 1; i < steps.length; i++) {
    if (p.startsWith(steps[i].href)) return 'done';
  }
  if (idx === 0 && (p === '/datlas' || p === '/datlas/' || p === '')) return 'pending';
  return 'pending';
}
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Datlas — Cargá, limpiá y explorá tus datasets en segundos. Sin instalación, sin dolor." />
    <title>{title} · Datlas</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg-primary: #0a0a14;
        --bg-secondary: #10101e;
        --bg-card: #16162a;
        --bg-card-hover: #1e1e3a;
        --border: #2a2a4a;
        --border-hover: #4a4a6a;
        --text-primary: #e8e8f5;
        --text-secondary: #9494b8;
        --text-muted: #4a4a6a;
        --accent: #a78bfa;
        --accent-hover: #c4b5fd;
        --accent-bg: rgba(167, 139, 250, 0.12);
        --btn-primary: #7c3aed;
        --btn-primary-hover: #6d28d9;
        --green: #22c55e;
        --green-bg: rgba(34, 197, 94, 0.1);
        --red: #ef4444;
        --red-bg: rgba(239, 68, 68, 0.1);
        --yellow: #f59e0b;
        --yellow-bg: rgba(245, 158, 11, 0.1);
        --blue: #3b82f6;
        --font-base: 'Inter', system-ui, -apple-system, sans-serif;
        --max-width: 960px;
        --radius: 12px;
        --radius-sm: 8px;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-size: 17px; scroll-behavior: smooth; }
      body {
        font-family: var(--font-base);
        background: var(--bg-primary);
        color: var(--text-primary);
        line-height: 1.6;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      header {
        background: var(--bg-secondary);
        border-bottom: 1px solid var(--border);
        padding: 0.7rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.6rem;
        position: sticky;
        top: 0;
        z-index: 100;
        backdrop-filter: blur(8px);
      }
      .logo {
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--accent);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      .logo span { color: var(--text-primary); font-weight: 400; }
      .logo small { font-size: 0.65rem; color: var(--text-muted); font-weight: 400; display: none; }
      @media (min-width: 600px) { .logo small { display: inline; } }

      nav { display: flex; gap: 0.2rem; flex-wrap: wrap; }
      nav a {
        color: var(--text-secondary);
        text-decoration: none;
        font-weight: 500;
        font-size: 0.82rem;
        padding: 0.35rem 0.8rem;
        border-radius: var(--radius-sm);
        transition: all 0.2s;
      }
      nav a:hover { color: var(--accent-hover); background: var(--accent-bg); }
      nav a.active { color: var(--accent-hover); background: var(--accent-bg); }

      .step-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0;
        padding: 1.2rem 2rem 0.8rem;
        background: var(--bg-secondary);
        border-bottom: 1px solid var(--border);
        flex-wrap: wrap;
      }
      .step-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 1rem;
        border-radius: var(--radius-sm);
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text-muted);
        text-decoration: none;
        transition: all 0.25s;
        position: relative;
      }
      .step-item .step-num {
        width: 24px; height: 24px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.7rem; font-weight: 700;
        background: var(--bg-card);
        border: 2px solid var(--border);
        color: var(--text-muted);
        transition: all 0.25s;
      }
      .step-item.active { color: var(--accent-hover); }
      .step-item.active .step-num { background: var(--btn-primary); border-color: var(--btn-primary); color: white; }
      .step-item.done { color: var(--green); }
      .step-item.done .step-num { background: var(--green); border-color: var(--green); color: #111; }
      .step-item:hover { background: var(--accent-bg); }
      .step-connector {
        width: 24px;
        height: 2px;
        background: var(--border);
        flex-shrink: 0;
      }
      .step-connector.done { background: var(--green); }

      main {
        flex: 1;
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 1.5rem 2rem;
        width: 100%;
      }

      footer {
        text-align: center;
        padding: 1.2rem;
        color: var(--text-muted);
        font-size: 0.75rem;
        border-top: 1px solid var(--border);
        background: var(--bg-secondary);
      }
      footer a { color: #7c6faf; text-decoration: none; }
      footer a:hover { color: var(--accent); }

      .btn {
        display: inline-flex; align-items: center; gap: 0.4rem;
        padding: 0.6rem 1.4rem;
        border-radius: var(--radius-sm);
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
        font-family: inherit;
        line-height: 1.2;
      }
      .btn:active { transform: scale(0.97); }
      .btn-primary { background: var(--btn-primary); color: white; }
      .btn-primary:hover { background: var(--btn-primary-hover); }
      .btn-outline {
        border: 2px solid var(--border);
        color: var(--accent-hover);
        background: transparent;
      }
      .btn-outline:hover { border-color: var(--accent); background: var(--accent-bg); }
      .btn-success { background: var(--green); color: #111; }
      .btn-success:hover { background: #16a34a; }
      .btn-sm { padding: 0.35rem 0.9rem; font-size: 0.78rem; }
      .btn-lg { padding: 0.85rem 2rem; font-size: 1.05rem; }

      .card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.4rem;
        transition: border-color 0.2s;
      }
      .card:hover { border-color: var(--border-hover); }
      .card h3 { color: var(--accent-hover); margin-bottom: 0.5rem; font-size: 1rem; }

      .badge {
        display: inline-flex; align-items: center; gap: 0.25rem;
        padding: 0.15rem 0.5rem;
        border-radius: 20px;
        font-size: 0.68rem;
        font-weight: 600;
      }
      .badge-green { background: var(--green-bg); color: var(--green); }
      .badge-red { background: var(--red-bg); color: var(--red); }
      .badge-yellow { background: var(--yellow-bg); color: var(--yellow); }
      .badge-blue { background: rgba(59, 130, 246, 0.1); color: var(--blue); }

      input, select, textarea {
        font-family: inherit;
        font-size: 0.9rem;
        padding: 0.55rem 0.9rem;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border);
        background: var(--bg-secondary);
        color: var(--text-primary);
        outline: none;
        transition: border-color 0.2s;
      }
      input:focus, select:focus { border-color: var(--accent); }

      table { width: 100%; border-collapse: collapse; }
      th { text-align: left; color: var(--text-secondary); font-weight: 600; letter-spacing: 0.3px; }
      td, th { padding: 0.35rem 0.5rem; }
      tr { border-bottom: 1px solid var(--border); }

      .page-title {
        text-align: center;
        margin-bottom: 1.8rem;
      }
      .page-title h1 { font-size: 1.8rem; font-weight: 800; margin-bottom: 0.25rem; }
      .page-title p { color: var(--text-secondary); font-size: 0.9rem; max-width: 500px; margin: 0 auto; }

      .btn-group { display: flex; gap: 0.6rem; flex-wrap: wrap; }
      .mt-1 { margin-top: 1rem; }
      .mt-2 { margin-top: 2rem; }
      .mb-1 { margin-bottom: 1rem; }
      .mb-2 { margin-bottom: 2rem; }
      .text-center { text-align: center; }
      .text-secondary { color: var(--text-secondary); }
      .text-muted { color: var(--text-muted); }
      .text-green { color: var(--green); }
      .text-red { color: var(--red); }

      .fade-in { animation: fadeIn 0.35s ease-out; }
      @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

      @media (max-width: 600px) {
        html { font-size: 16px; }
        header { padding: 0.6rem 1rem; }
        .step-bar { padding: 0.8rem 1rem 0.5rem; gap: 0.2rem; }
        .step-item { font-size: 0.72rem; padding: 0.3rem 0.5rem; }
        .step-item .step-num { width: 20px; height: 20px; font-size: 0.6rem; }
        .step-connector { width: 12px; }
        main { padding: 1rem; }
        .page-title h1 { font-size: 1.4rem; }
      }
    </style>
  </head>
  <body>
    <header>
      <a href="/datlas" class="logo">
        ⚡ Datlas
        <small><span>·</span> analizá tus datos</small>
      </a>
      <nav>
        <a href="/datlas" class={path === '/datlas/' || path === '/datlas' ? 'active' : ''}>Inicio</a>
        <a href="/datlas/subir" class={path.startsWith('/datlas/subir') ? 'active' : ''}>Subir</a>
        <a href="/datlas/limpiar" class={path.startsWith('/datlas/limpiar') ? 'active' : ''}>Limpiar</a>
        <a href="/datlas/explorar" class={path.startsWith('/datlas/explorar') ? 'active' : ''}>Explorar</a>
      </nav>
    </header>

    <div class="step-bar">
      {steps.map((s, i) => {
        const status = stepStatus(i);
        const connector = i > 0;
        const prevStatus = i > 0 ? stepStatus(i - 1) : 'done';
        return (
          <>
            {connector && <div class={`step-connector ${status === 'done' || prevStatus === 'done' ? 'done' : ''}`}></div>}
            <a href={s.href} class={`step-item ${status}`}>
              <span class="step-num">{status === 'done' ? '✓' : i + 1}</span>
              <span>{s.label}</span>
            </a>
          </>
        );
      })}
    </div>

    <main>
      <slot />
    </main>

    <footer>
      <p>⚡ Datlas · <a href="https://github.com/LeandroBenjaminL/datlas">GitHub</a> · 2026</p>
    </footer>
  </body>
</html>
