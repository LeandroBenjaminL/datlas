---
const { title = 'Datlas' } = Astro.props;
const path = Astro.url.pathname;

const navItems = [
  { label: 'Inicio', href: '/datlas' },
  { label: 'Subir', href: '/datlas/subir' },
  { label: 'Limpiar', href: '/datlas/limpiar' },
  { label: 'Explorar', href: '/datlas/explorar' },
  { label: 'Pipeline', href: '/datlas/pipeline' },
  { label: 'Flow', href: '/datlas/flow' },
];

const steps = [
  { label: 'Subir', icon: '📁', href: '/datlas/subir' },
  { label: 'Limpiar', icon: '🧹', href: '/datlas/limpiar' },
  { label: 'Explorar', icon: '🔍', href: '/datlas/explorar' },
  { label: 'Pipeline', icon: '⚡', href: '/datlas/pipeline' },
  { label: 'Flow', icon: '🌊', href: '/datlas/flow' },
];

function stepStatus(idx) {
  const p = path.replace(/\/$/, '');
  const href = steps[idx].href;
  if (p === href || p.startsWith(href + '/')) return 'active';
  for (let i = idx + 1; i < steps.length; i++) {
    if (p.startsWith(steps[i].href)) return 'done';
  }
  if (idx === 0 && (p === '/datlas' || p === '/datlas/' || p === '')) return 'pending';
  return 'pending';
}

function navClass(href) {
  const p = path.replace(/\/$/, '');
  const h = href.replace(/\/$/, '');
  if (p === h) return 'active';
  if (h !== '/datlas' && p.startsWith(h)) return 'active';
  return '';
}
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Datlas — Cargá, limpiá y explorá tus datasets en segundos." />
    <title>{title} · Datlas</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; }

      :root {
        --bg-primary: #0a0a12;
        --bg-secondary: #12121e;
        --bg-glass: rgba(18, 18, 30, 0.75);
        --border-glass: rgba(0, 240, 255, 0.08);
        --color-true: #00f0ff;
        --color-false: #1a1a2e;
        --color-true-glow: 0 0 20px rgba(0, 240, 255, 0.4), 0 0 60px rgba(0, 240, 255, 0.1);
        --color-accent: #7b61ff;
        --color-accent-glow: 0 0 15px rgba(123, 97, 255, 0.3);
        --color-danger: #ff4466;
        --color-danger-glow: 0 0 12px rgba(255, 68, 102, 0.3);
        --color-text: #e0e0e8;
        --color-text-dim: #5a5a72;
        --color-gate-bg: #16162a;
        --color-gate-border: #2a2a44;
        --font-mono: 'JetBrains Mono', 'Fira Code', 'SF Mono', monospace;
        --font-sans: 'Inter', 'SF Pro', system-ui, sans-serif;
        --ease-expo: cubic-bezier(0.16, 1, 0.3, 1);
        --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
        --green: #22c55e;
        --green-bg: rgba(34, 197, 94, 0.1);
        --red: #ef4444;
        --red-bg: rgba(239, 68, 68, 0.1);
        --yellow: #f59e0b;
        --yellow-bg: rgba(245, 158, 11, 0.1);
        --radius: 12px;
        --radius-sm: 8px;
      }

      body {
        font-family: var(--font-mono);
        background: var(--bg-primary);
        color: var(--color-text);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        user-select: none;
        background-image: radial-gradient(circle at 1px 1px, rgba(0, 240, 255, 0.025) 1px, transparent 1px);
        background-size: 40px 40px;
      }
      a { color: inherit; text-decoration: none; }

      .top-bar {
        position: sticky;
        top: 0;
        left: 0;
        right: 0;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 1.5rem;
        z-index: 200;
        background: linear-gradient(180deg, var(--bg-primary) 60%, transparent);
        pointer-events: none;
      }
      .top-bar > * { pointer-events: auto; }

      .app-title {
        font-family: var(--font-mono);
        font-size: .7rem;
        font-weight: 600;
        letter-spacing: .2em;
        text-transform: uppercase;
        opacity: .4;
        color: var(--color-text);
      }
      .app-title:hover { opacity: .7; }

      .top-actions {
        display: flex;
        gap: .5rem;
        align-items: center;
      }

      .nav-btn {
        font-family: var(--font-mono);
        font-size: .6rem;
        font-weight: 600;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--color-text-dim);
        background: var(--bg-glass);
        backdrop-filter: blur(20px) saturate(1.2);
        border: 1px solid var(--border-glass);
        border-radius: 8px;
        padding: .45rem .9rem;
        cursor: pointer;
        transition: all .3s var(--ease-expo);
        white-space: nowrap;
      }
      .nav-btn:hover {
        color: var(--color-true);
        border-color: rgba(0, 240, 255, 0.2);
        box-shadow: var(--color-true-glow);
      }
      .nav-btn.active {
        color: var(--color-true);
        border-color: rgba(0, 240, 255, 0.2);
      }

      .action-btn {
        font-family: var(--font-mono);
        font-size: .6rem;
        font-weight: 600;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--color-text-dim);
        background: var(--bg-glass);
        backdrop-filter: blur(20px) saturate(1.2);
        border: 1px solid var(--border-glass);
        border-radius: 8px;
        padding: .45rem .9rem;
        cursor: pointer;
        transition: all .3s var(--ease-expo);
        white-space: nowrap;
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        text-decoration: none;
        line-height: 1;
      }
      .action-btn:hover {
        color: var(--color-true);
        border-color: rgba(0, 240, 255, 0.2);
        box-shadow: var(--color-true-glow);
      }
      .action-btn:active { transform: scale(.97); }
      .action-btn.primary {
        color: var(--color-true);
        border-color: rgba(0, 240, 255, 0.2);
      }
      .action-btn.primary:hover {
        box-shadow: var(--color-true-glow);
        background: rgba(0, 240, 255, 0.06);
      }
      .action-btn.success {
        color: var(--green);
        border-color: rgba(34, 197, 94, 0.2);
      }
      .action-btn.success:hover {
        box-shadow: 0 0 15px rgba(34, 197, 94, 0.3);
        background: rgba(34, 197, 94, 0.06);
      }
      .action-btn.danger:hover {
        color: var(--color-danger);
        border-color: rgba(255, 68, 102, 0.2);
        box-shadow: var(--color-danger-glow);
      }
      .action-btn.secondary {
        border-color: var(--color-gate-border);
      }
      .action-btn.secondary:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
        box-shadow: var(--color-accent-glow);
      }
      .action-btn.sm { padding: .3rem .65rem; font-size: .52rem; }
      .action-btn.lg { padding: .55rem 1.2rem; font-size: .68rem; }

      .step-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0;
        padding: .6rem 1.5rem;
        background: var(--bg-glass);
        backdrop-filter: blur(20px) saturate(1.2);
        border-top: 1px solid var(--border-glass);
        border-bottom: 1px solid var(--border-glass);
        flex-wrap: wrap;
      }
      .step-item {
        display: flex;
        align-items: center;
        gap: .3rem;
        padding: .3rem .6rem;
        border-radius: 8px;
        font-size: .58rem;
        font-weight: 600;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--color-text-dim);
        text-decoration: none;
        transition: all .3s var(--ease-expo);
      }
      .step-item .step-num {
        width: 18px; height: 18px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: .55rem; font-weight: 700;
        border: 1.5px solid var(--color-text-dim);
        color: var(--color-text-dim);
        transition: all .3s var(--ease-expo);
      }
      .step-item:hover {
        color: var(--color-true);
        background: rgba(0, 240, 255, 0.04);
      }
      .step-item.active { color: var(--color-true); }
      .step-item.active .step-num {
        border-color: var(--color-true);
        color: var(--color-true);
        box-shadow: 0 0 8px rgba(0, 240, 255, 0.3);
      }
      .step-item.done { color: var(--green); }
      .step-item.done .step-num {
        border-color: var(--green);
        color: var(--green);
      }
      .step-connector {
        width: 16px;
        height: 1px;
        background: var(--color-text-dim);
        opacity: .3;
        flex-shrink: 0;
      }
      .step-connector.done { background: var(--green); opacity: .6; }

      main {
        flex: 1;
        max-width: 960px;
        margin: 0 auto;
        padding: 1.5rem 2rem;
        width: 100%;
      }

      footer {
        text-align: center;
        padding: .8rem;
        font-size: .55rem;
        color: var(--color-text-dim);
        letter-spacing: .12em;
        text-transform: uppercase;
        border-top: 1px solid var(--border-glass);
        background: var(--bg-glass);
        backdrop-filter: blur(20px) saturate(1.2);
      }
      footer a:hover { color: var(--color-true); }

      .glass-card {
        background: var(--color-gate-bg);
        border: 1px solid var(--color-gate-border);
        border-radius: 12px;
        padding: 1.2rem;
        transition: border-color .3s var(--ease-expo), box-shadow .3s var(--ease-expo);
      }
      .glass-card:hover { border-color: var(--border-hover, #3a3a5a); }
      .glass-card h3 {
        font-size: .65rem;
        font-weight: 600;
        letter-spacing: .1em;
        text-transform: uppercase;
        margin-bottom: .4rem;
        color: var(--color-text);
      }

      .badge {
        display: inline-flex; align-items: center; gap: .25rem;
        padding: .1rem .45rem;
        border-radius: 20px;
        font-size: .52rem;
        font-weight: 600;
        letter-spacing: .04em;
        border: 1px solid transparent;
      }
      .badge-green {
        border-color: rgba(34, 197, 94, 0.3);
        color: var(--green);
        background: var(--green-bg);
      }
      .badge-red {
        border-color: rgba(239, 68, 68, 0.3);
        color: var(--red);
        background: var(--red-bg);
      }
      .badge-yellow {
        border-color: rgba(245, 158, 11, 0.3);
        color: var(--yellow);
        background: var(--yellow-bg);
      }
      .badge-cyan {
        border-color: rgba(0, 240, 255, 0.2);
        color: var(--color-true);
        background: rgba(0, 240, 255, 0.06);
      }

      input, select, textarea {
        font-family: var(--font-mono);
        font-size: .72rem;
        padding: .4rem .65rem;
        border-radius: 8px;
        border: 1px solid var(--color-gate-border);
        background: var(--color-gate-bg);
        color: var(--color-text);
        outline: none;
        transition: border-color .25s var(--ease-expo);
      }
      input:focus, select:focus {
        border-color: var(--color-true);
        box-shadow: 0 0 10px rgba(0, 240, 255, 0.1);
      }
      select option { background: var(--bg-secondary); color: var(--color-text); }

      table { width: 100%; border-collapse: collapse; font-size: .72rem; }
      th {
        text-align: left;
        color: var(--color-text-dim);
        font-weight: 600;
        font-size: .6rem;
        letter-spacing: .08em;
        text-transform: uppercase;
      }
      td, th { padding: .25rem .45rem; }
      tr { border-bottom: 1px solid var(--border-glass); }

      .page-title {
        text-align: center;
        margin-bottom: 1.5rem;
      }
      .page-title h1 {
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        margin-bottom: .25rem;
      }
      .page-title h1 .highlight { color: var(--color-true); }
      .page-title p {
        color: var(--color-text-dim);
        font-size: .68rem;
        max-width: 440px;
        margin: 0 auto;
      }

      .btn-group { display: flex; gap: .4rem; flex-wrap: wrap; }
      .mt-1 { margin-top: .8rem; }
      .mt-2 { margin-top: 1.5rem; }
      .mb-1 { margin-bottom: .8rem; }
      .mb-2 { margin-bottom: 1.5rem; }
      .text-center { text-align: center; }
      .text-secondary { color: var(--color-text-dim); }
      .text-green { color: var(--green); }
      .text-red { color: var(--red); }
      .text-cyan { color: var(--color-true); }

      .fade-in { animation: fadeIn .4s var(--ease-expo); }
      @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

      .spinner {
        display: inline-block;
        width: 24px; height: 24px;
        border: 2px solid var(--color-gate-border);
        border-top-color: var(--color-true);
        border-radius: 50%;
        animation: spin .7s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }

      @media (max-width: 600px) {
        html { font-size: 16px; }
        .hero h1 { font-size: 2.2rem; }
        .hero p { font-size: 1rem; }
        header { flex-direction: column; text-align: center; padding: 0.8rem 1rem; }
        nav { justify-content: center; gap: 1rem; }
        main { padding: 1rem; }
        .grid-3 { grid-template-columns: 1fr; }
        .btn { width: 100%; text-align: center; }
        .hero { padding: 2rem 1rem; }
        table { font-size: 0.75rem !important; }
        table td, table th { padding: 0.3rem !important; }
        .top-bar { padding: 0 1rem; }
        .nav-btn { font-size: .52rem; padding: .3rem .5rem; }
        .step-bar { padding: .4rem .5rem; gap: .1rem; }
        .step-item { font-size: .5rem; padding: .2rem .35rem; }
        .step-item .step-num { width: 16px; height: 16px; font-size: .45rem; }
        .step-connector { width: 8px; }
      }

      @media (min-width: 601px) and (max-width: 1024px) {
        .grid-3 { grid-template-columns: repeat(2, 1fr); }
        .hero h1 { font-size: 2.8rem; }
      }
    </style>
  </head>
  <body>
    <header class="top-bar">
      <a href="/datlas" class="app-title">DATLAS</a>
      <nav class="top-actions">
        {navItems.map(item => (
          <a href={item.href} class={`nav-btn ${navClass(item.href)}`}>{item.label}</a>
        ))}
      </nav>
    </header>

    <div class="step-bar">
      {steps.map((s, i) => {
        const status = stepStatus(i);
        const connector = i > 0;
        const prevStatus = i > 0 ? stepStatus(i - 1) : 'done';
        return (
          <>
            {connector && <div class={`step-connector ${status === 'done' || prevStatus === 'done' ? 'done' : ''}`}></div>}
            <a href={s.href} class={`step-item ${status}`}>
              <span class="step-num">{status === 'done' ? '✓' : i + 1}</span>
              <span>{s.label}</span>
            </a>
          </>
        );
      })}
    </div>

    <main>
      <slot />
    </main>

    <footer>DATLAS · <a href="https://github.com/LeandroBenjaminL/datlas">GITHUB</a> · 2026</footer>
  </body>
</html>
