---
// Layout principal de Datlas — todas las páginas heredan de acá
const { title = 'Datlas' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Datlas — El titán que carga tus datasets, los limpia, los explora y los transforma." />
    <title>{title} | Datlas</title>
    <style>
      /* ── Reset y base ── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-size: 18px; scroll-behavior: smooth; }
      body {
        font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
        background: #0a0a12;
        color: #e2e2f0;
        line-height: 1.7;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* ── Header ── */
      header {
        background: linear-gradient(135deg, #1a1040 0%, #0d1b3e 50%, #0a0a12 100%);
        border-bottom: 1px solid #2a2a45;
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
      }
      header a.logo {
        font-size: 1.6rem;
        font-weight: 800;
        color: #a78bfa;
        text-decoration: none;
        letter-spacing: -0.5px;
      }
      header a.logo span { color: #e2e2f0; font-weight: 400; }

      nav {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
      }
      nav a {
        color: #94a3b8;
        text-decoration: none;
        font-weight: 500;
        font-size: 0.95rem;
        transition: color 0.2s;
        padding: 0.3rem 0;
        border-bottom: 2px solid transparent;
      }
      nav a:hover, nav a.active {
        color: #c4b5fd;
        border-bottom-color: #a78bfa;
      }

      /* ── Main ── */
      main {
        flex: 1;
        max-width: 1100px;
        margin: 0 auto;
        padding: 2rem;
        width: 100%;
      }

      /* ── Footer ── */
      footer {
        text-align: center;
        padding: 2rem;
        color: #4a4a6a;
        font-size: 0.85rem;
        border-top: 1px solid #1a1a2e;
      }
      footer a { color: #7c6faf; text-decoration: none; }
      footer a:hover { color: #a78bfa; }

      /* ── Componentes ── */
      .hero {
        text-align: center;
        padding: 4rem 1rem;
      }
      .hero h1 {
        font-size: 3.5rem;
        font-weight: 900;
        background: linear-gradient(135deg, #a78bfa, #60a5fa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 1rem;
      }
      .hero p {
        font-size: 1.2rem;
        color: #94a3b8;
        max-width: 600px;
        margin: 0 auto 2rem;
      }

      .btn {
        display: inline-block;
        padding: 0.75rem 2rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1rem;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
      }
      .btn-primary {
        background: #7c3aed;
        color: white;
      }
      .btn-primary:hover { background: #6d28d9; transform: translateY(-1px); }
      .btn-outline {
        border: 2px solid #4a4a6a;
        color: #c4b5fd;
      }
      .btn-outline:hover { border-color: #a78bfa; background: rgba(167,139,250,0.1); }

      .grid-3 {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        margin: 3rem 0;
      }
      .card {
        background: #12122a;
        border: 1px solid #1e1e3a;
        border-radius: 12px;
        padding: 2rem;
        transition: border-color 0.2s, transform 0.2s;
      }
      .card:hover {
        border-color: #3a3a5a;
        transform: translateY(-2px);
      }
      .card h3 { color: #c4b5fd; margin-bottom: 0.75rem; font-size: 1.2rem; }
      .card p { color: #94a3b8; font-size: 0.95rem; }

      .badge {
        display: inline-block;
        padding: 0.2rem 0.7rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        background: rgba(167,139,250,0.15);
        color: #c4b5fd;
        border: 1px solid rgba(167,139,250,0.3);
        margin-bottom: 1rem;
      }

      /* ── Responsive ── */
      @media (max-width: 600px) {
        .hero h1 { font-size: 2.2rem; }
        header { flex-direction: column; text-align: center; }
      }
    </style>
  </head>
  <body>
    <header>
      <a href="/datlas" class="logo">⚡ Datlas<span>.io</span></a>
      <nav>
        <a href="/datlas">Inicio</a>
        <a href="/datlas/subir">Subir</a>
        <a href="/datlas/limpiar">Limpiar</a>
        <a href="/datlas/explorar">Explorar</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>Datlas · <a href="https://github.com/LeandroBenjaminL/datlas">GitHub</a> · Arquitectura profesional · 2026</p>
    </footer>
  </body>
</html>
