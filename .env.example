# ============================================
# Datlas — Variables de Entorno
# ============================================
# Copiá este archivo a .env y ajustá si querés:
#   cp .env.example .env

# ── PostgreSQL ──
POSTGRES_USER=datlas
POSTGRES_PASSWORD=datlas_secreto_2026
POSTGRES_DB=datlas_db
POSTGRES_PORT=5432

# ── pgAdmin ──
PGADMIN_EMAIL=admin@datlas.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# ── Security ──
# API_KEY=              # Dejar vacío para dev (sin auth). Setear en producción.
CORS_ORIGINS=*          # Orígenes separados por coma, * para dev
RATE_LIMIT=100/minute    # Límite global de requests por IP
MAX_UPLOAD_SIZE_MB=50   # Tamaño máximo de archivo a subir

# ── AWS S3 (storage de archivos) ──
# Descomentá para usar S3 en vez de disco local.
# Si S3_BUCKET está vacío, se usa almacenamiento local (default).
# AWS_ACCESS_KEY_ID=tu_access_key
# AWS_SECRET_ACCESS_KEY=tu_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET=datlas-datasets
